# Database
DATABASE_URL=postgresql://mediwyz:mediwyz_secret@localhost:5432/mediwyz

# App URLs
# Socket.IO URL — points to NestJS backend (port 3001)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps — get your key at console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Geocoding API
# Restrict HTTP referrers: localhost:3000/*, mediwyz.com/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_KEY_HERE

# ─── NestJS Backend ──────────────────────────────────────────────────────
# NestJS is the ONLY backend. Next.js proxies all /api/* to NestJS.
API_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001

# App Branding (change these to rebrand without touching code)
NEXT_PUBLIC_APP_NAME=MediWyz
NEXT_PUBLIC_APP_SHORT_NAME=MediWyz
NEXT_PUBLIC_APP_DOMAIN=mediwyz.com
APP_TAGLINE=Your trusted healthcare companion
APP_EMAIL=info@mediwyz.com

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-here

# Port (default 3000, Docker uses 8080)
PORT=3000

# Super Admin (auto-created on server start if not exists)
SUPER_ADMIN_EMAIL=admin@mediwyz.com
SUPER_ADMIN_PASSWORD=Admin123!
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=MediWyz

# Groq API Key (for document verification via VLM/LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Commission Rates (override defaults)
# PLATFORM_COMMISSION_RATE=5
# REGIONAL_COMMISSION_RATE=10
