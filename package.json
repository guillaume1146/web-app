    "@iconify-json/healthicons": "^1.2.12",
    "@iconify/react": "^6.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.16.1",
    "@tabler/icons-react": "^3.41.1",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "framer-motion": "^12.23.12",
    "healthicons-react": "^3.5.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "next": "15.5.12",
    "pdfjs-dist": "^4.10.38",
    "prisma": "^6.16.1",
