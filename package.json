{
  "name": "mediwyz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:api": "node e2e/e2e-registration-auth.js",
    "test:migration": "playwright test e2e/nestjs-migration.spec.ts --reporter=list",
    "test:api-format": "vitest run app/api/__tests__/nestjs-proxy-format.test.ts",
    "test:all": "bash scripts/test-nestjs-migration.sh --skip-start",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap sync android && npx cap open android",
    "mobile:ios": "npx cap sync ios && npx cap open ios",
    "mobile:build:apk": "npx cap sync android && cd android && ./gradlew assembleDebug && cd ..",
    "mobile:build:release": "npx cap sync android && cd android && ./gradlew assembleRelease && cd .."
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
