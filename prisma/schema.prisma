// ─── Admin action audit log ────────────────────────────────────────────────
// Every admin mutation goes here: account status changes, role-config edits,
// required-document config edits, document approvals/rejections, commission
// config edits. The adminId is always the authenticated user who performed
// the action; targetType + targetId identify the row that changed.
model AdminActionLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String // e.g. "account.suspend", "document.approve", "role.create"
  targetType String // e.g. "User", "Document", "ProviderRole"
  targetId   String?
  details    Json? // before/after snapshot, reason, etc.
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String // appointment, prescription, lab_result, message, system, workflow, insurance
  title         String
  message       String
  referenceId   String?
  referenceType String?
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  // Structured payload — drives contextual CTAs on the notification card.
  // Shape: { stepCode?, bookingId?, providerName?, actions?: [{label, href}] }
  payload Json?

  // Grouping — notifications sharing a groupKey on the same day collapse
  // into one card: "Your lab test moved 3 steps today".
  groupKey String?

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@index([userId, readAt])
  @@index([userId, groupKey, createdAt])
}

