  @@index([category])
}

model NurseServiceCatalog {
  id          String       @id @default(uuid())
  nurseId     String
  nurse       NurseProfile @relation(fields: [nurseId], references: [id], onDelete: Cascade)
  serviceName String
  category    String // Wound Care, Monitoring, Medication, Assessment, etc.
  description String
  price       Float
  currency    String       @default("MUR")
  duration    String // e.g. "30 minutes", "1 hour"
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([nurseId])
  @@index([category])
}

model NannyServiceCatalog {
  id          String       @id @default(uuid())
  nannyId     String
  nanny       NannyProfile @relation(fields: [nannyId], references: [id], onDelete: Cascade)
  serviceName String
  category    String // Educational, Creative, Health, Daily Care, etc.
  description String
  price       Float
  currency    String       @default("MUR")
  ageRange    String? // e.g. "0-2 years", "3-6 years", "All ages"
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([nannyId])
  @@index([category])
}

model EmergencyServiceListing {
  id              String                 @id @default(uuid())
  workerId        String
  worker          EmergencyWorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  serviceName     String
  serviceType     String // Ambulance, First Aid, Rescue, Medical Transport
  description     String
  responseTime    String // e.g. "15 minutes"
  available24h    Boolean                @default(true)
  coverageArea    String
  contactNumber   String
  price           Float?
  currency        String                 @default("MUR")
  specializations String[]
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([workerId])
  @@index([serviceType])
}

model InsurancePlanListing {
  id              String              @id @default(uuid())
  insuranceRepId  String
  insuranceRep    InsuranceRepProfile @relation(fields: [insuranceRepId], references: [id], onDelete: Cascade)
  planName        String
  planType        String // Health, Dental, Vision, Life, Family
  description     String
  monthlyPremium  Float
  annualPremium   Float?
  currency        String              @default("MUR")
  coverageAmount  Float
  deductible      Float?
  coverageDetails String[]
  eligibility     String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  claims InsuranceClaim[]

  @@index([insuranceRepId])
  @@index([planType])
}

model InsuranceClaim {
  id               String               @id @default(uuid())
  claimId          String               @unique @default(uuid())
  insuranceRepId   String
  insuranceRep     InsuranceRepProfile  @relation(fields: [insuranceRepId], references: [id], onDelete: Cascade)
  patientId        String
  patient          PatientProfile       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  planId           String?
  plan             InsurancePlanListing? @relation(fields: [planId], references: [id])
  policyHolderName String
  description      String
  policyType       String
  claimAmount      Float
  status           String               @default("pending") // pending, approved, rejected
  submittedDate    DateTime             @default(now())
  resolvedDate     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([insuranceRepId])
  @@index([patientId])
  @@index([status])
}

// ─── Trial Wallet & Transactions ─────────────────────────────────────────────

model UserWallet {
  id            String              @id @default(uuid())
  userId        String              @unique
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Float               @default(4500)
  currency      String              @default("MUR")
  initialCredit Float               @default(4500)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  transactions  WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id                   String     @id @default(uuid())
  walletId             String
  wallet               UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type                 String     // credit, debit
  amount               Float
  description          String
  serviceType          String?    // consultation, medicine, lab_test, emergency, subscription
  referenceId          String?
  balanceBefore        Float
  balanceAfter         Float
  status               String     @default("completed")
  platformCommission   Float?     // 5% platform fee
  regionalCommission   Float?     // 10% regional admin fee
  providerAmount       Float?     // 85% provider earnings
  regionalAdminId      String?    // regional admin who gets commission
  createdAt            DateTime   @default(now())

  @@index([walletId])
  @@index([walletId, createdAt])
  @@index([createdAt])
  @@index([regionalAdminId])
  @@index([serviceType])
}

// ─── Doctor Posts (Social Feed) ──────────────────────────────────────────────

model DoctorPost {
  id          String        @id @default(uuid())
  authorId    String
  author      User          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  category    String?
  tags        String[]
  imageUrl    String?
  likeCount   Int           @default(0)
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  comments    PostComment[]
  likes       PostLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([category])
  @@index([isPublished, createdAt])
}

model PostComment {
  id        String     @id @default(uuid())
  postId    String
  post      DoctorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([postId])
  @@index([authorId])
}

model PostLike {
  id        String     @id @default(uuid())
  postId    String
  post      DoctorPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("PostLiker", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

// ─── Booking Models (Lab Test & Emergency) ──────────────────────────────────

model LabTestBooking {
  id          String          @id @default(uuid())
  patientId   String
  patient     PatientProfile  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  labTechId   String?
  labTech     LabTechProfile? @relation(fields: [labTechId], references: [id])
  testName       String
  scheduledAt    DateTime
  status         String          @default("pending") // pending, upcoming, completed, cancelled
  sampleType     String?
  notes          String?
  price          Float?
  resultFindings String?
  resultNotes    String?
  resultDate     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([patientId])
  @@index([labTechId])
  @@index([scheduledAt])
  @@index([status])
}

model EmergencyBooking {
  id            String                  @id @default(uuid())
  patientId     String
  patient       PatientProfile          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  responderId   String?
  responder     EmergencyWorkerProfile? @relation(fields: [responderId], references: [id])
  emergencyType String
  location      String
  contactNumber String
  status        String                  @default("pending") // pending, dispatched, en_route, resolved, cancelled
  notes         String?
  priority      String                  @default("medium") // low, medium, high, critical
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([patientId])
  @@index([responderId])
  @@index([status])
}

// ─── Provider Availability ──────────────────────────────────────────────────

model ProviderAvailability {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek    Int      // 0=Sunday, 6=Saturday
  startTime    String   // "09:00" (24h)
  endTime      String   // "17:00"
  slotDuration Int      @default(60) // minutes per slot (30, 60, etc.)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, dayOfWeek, startTime])
  @@index([userId])
  @@index([dayOfWeek])
}

// ─── AI Chat Models ──────────────────────────────────────────────────────────

model AiChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AiChatMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AiChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String        // "user" | "assistant" | "system"
  content   String
  createdAt DateTime      @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model AiPatientInsight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime // the date the insight refers to (e.g. "Monday" → resolved to actual date)
  category  String   // "food", "exercise", "symptom", "medication", "sleep", "water", "mood"
  summary   String   // concise summary: "Ate sardines for lunch, rice and vegetables for dinner"
  details   Json?    // optional structured data: { meals: [...], nutrients: [...] }
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([userId, category])
  @@index([createdAt])
}

// ─── Health Tracker Models ──────────────────────────────────────────────────

model HealthTrackerProfile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  heightCm            Float?
  weightKg            Float?
  age                 Int?
  gender              String?
  activityLevel       ActivityLevel @default(moderately_active)
  weightGoal          WeightGoal    @default(maintain)
  targetCalories      Int?
  targetWaterMl       Int           @default(2000)
  targetExerciseMin   Int           @default(30)
  targetSleepMin      Int           @default(480)
  dietaryPreferences  String[]
  allergenSettings    String[]
  tdeeCalories        Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([userId])
}

model FoodEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  time        DateTime
  mealType    MealType
  name        String
  calories    Int
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  fiber       Float    @default(0)
  quantity    Float    @default(1)
  unit        String   @default("serving")
  servingSize String?
  foodDbId    String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
  @@index([userId, mealType])
}

model ExerciseEntry {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  exerciseType   String
  durationMin    Int
  caloriesBurned Int
  intensity      ExerciseIntensity @default(moderate)
  notes          String?
  createdAt      DateTime          @default(now())

  @@index([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  @@index([userId, date])
}

// ─── Sleep Tracking ─────────────────────────────────────────────────────────

enum SleepQuality {
  terrible
  poor
  fair
  good
  excellent
}

model SleepEntry {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  sleepStart  DateTime?
  sleepEnd    DateTime?
  durationMin Int
  quality     SleepQuality @default(fair)
  notes       String?
  createdAt   DateTime     @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model DailyGoalSnapshot {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime
  caloriesConsumed  Int      @default(0)
  caloriesBurned    Int      @default(0)
  waterConsumedMl   Int      @default(0)
  exerciseMinutes   Int      @default(0)
  targetCalories    Int
  targetWaterMl     Int
  targetExerciseMin Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model MealPlanEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  dayOfWeek     Int
  mealType      MealType
  name          String
  description   String?
  calories      Int
  protein       Float    @default(0)
  carbs         Float    @default(0)
  fat           Float    @default(0)
  isGenerated   Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId, weekStartDate])
  @@index([userId, dayOfWeek])
}

model FoodDatabase {
  id          String  @id @default(cuid())
  name        String
  category    String
  calories    Int
  protein     Float   @default(0)
  carbs       Float   @default(0)
  fat         Float   @default(0)
  fiber       Float   @default(0)
  servingSize String
  unit        String  @default("serving")
  isLocal     Boolean @default(false)

  @@index([category])
  @@index([name])
}

// ─── Generic Provider Reviews ───────────────────────────────────────────────

model ProviderReview {
  id             String    @id @default(uuid())
  providerUserId String
  providerUser   User      @relation("ReviewsReceived", fields: [providerUserId], references: [id], onDelete: Cascade)
  reviewerUserId String
  reviewerUser   User      @relation("ReviewsGiven", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  providerType   String    // DOCTOR, NURSE, NANNY, PHARMACIST, LAB_TECHNICIAN, EMERGENCY_WORKER
  rating         Int
  comment        String
  verified       Boolean   @default(false)
  helpfulCount   Int       @default(0)
  response       String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([providerUserId, reviewerUserId, providerType])
  @@index([providerUserId])
  @@index([providerUserId, providerType])
  @@index([providerType])
  @@index([createdAt])
}

// ─── Platform Commission Configuration (singleton) ──────────────────────────

model PlatformConfig {
  id                     String   @id @default(uuid())
  platformCommissionRate Float    @default(5)   // % to platform
  regionalCommissionRate Float    @default(10)  // % default to regional admin
  providerCommissionRate Float    @default(85)  // % to service provider
  currency               String   @default("MUR")
  trialWalletAmount      Float    @default(4500)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── Role Feature Configuration (admin-configurable) ────────────────────────

model RoleFeatureConfig {
  id         String   @id @default(uuid())
  userType   String
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userType, featureKey])
  @@index([userType])
}

// ─── Required Document Configuration (admin-configurable) ───────────────────

model RequiredDocumentConfig {
  id           String   @id @default(uuid())
  userType     String
  documentName String
  required     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userType, documentName])
  @@index([userType])
}

// ─── User Preferences ──────────────────────────────────────────────────────

model UserPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language        String   @default("en") // en, fr, mfe
  timezone        String   @default("Indian/Mauritius")
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  smsNotifications      Boolean @default(false)
  appointmentReminders  Boolean @default(true)
  marketingEmails       Boolean @default(false)
  profileVisibility     String  @default("public") // public, connections, private
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ─── Referral Click Tracking ─────────────────────────────────────────────────

model ReferralClick {
  id              String    @id @default(uuid())
  referralCode    String
  utmSource       String?   // facebook, instagram, linkedin, twitter, whatsapp, email, website, tiktok, youtube
  utmMedium       String?   // social, messaging, direct, email
  utmCampaign     String?   // campaign identifier
  location        String?   // geographic location
  landingPage     String?   // which page they landed on
  convertedUserId String?   // null until signup, then linked to User.id
  convertedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([referralCode])
  @@index([utmSource])
  @@index([createdAt])
  @@index([convertedUserId])
}

// ─── User Connections ────────────────────────────────────────────────────────

model UserConnection {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("ConnectionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ConnectionsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([receiverId, status])
}
