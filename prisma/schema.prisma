// ─── Generic Service Booking (for new roles: caregiver, physio, dentist, etc.) ─

model ServiceBooking {
  id                 String    @id @default(uuid())
  patientId          String
  providerUserId     String
  providerType       UserType // Any provider type (dynamic — not limited to specific roles)
  providerName       String?
  scheduledAt        DateTime
  duration           Int       @default(30)
  type               String    @default("in_person") // in_person, home_visit, video
  status             String    @default("pending") // pending, accepted, in_progress, completed, cancelled
  reason             String?
  notes              String?
  serviceName        String?
  servicePrice       Float?
  specialty          String?
  location           String?
  roomId             String?
  priority           String?   @default("normal")
  cancellationReason String?
  cancelledBy        String?
  cancelledAt        DateTime?
  metadata           Json? // Role-specific data (e.g., children[], sampleType, testName, emergencyType)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime? // soft-delete

  @@index([patientId])
  @@index([providerUserId])
  @@index([providerType])
  @@index([scheduledAt])
  @@index([status])
  @@index([deletedAt])
}

// ─── Provider Availability ──────────────────────────────────────────────────

model ProviderAvailability {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0=Sunday, 6=Saturday
  startTime    String // "09:00" (24h)
  endTime      String // "17:00"
  slotDuration Int      @default(60) // minutes per slot (30, 60, etc.)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, dayOfWeek, startTime])
  @@index([userId])
  @@index([dayOfWeek])
}

// ─── Booked Slots (auto-blocked on acceptance, released on cancellation) ────

model BookedSlot {
  id             String   @id @default(uuid())
  providerUserId String
  bookingId      String
  date           DateTime // The date of the booking
  startTime      String // "10:00"
  endTime        String // "10:30"
  status         String   @default("booked") // booked, cancelled, completed
  createdAt      DateTime @default(now())

  @@unique([providerUserId, date, startTime])
  @@index([providerUserId, date])
  @@index([bookingId])
}

// ─── AI Chat Models ──────────────────────────────────────────────────────────

model AiChatSession {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String          @default("New Chat")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AiChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant" | "system"
  content   String
  createdAt DateTime      @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model AiPatientInsight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime // the date the insight refers to (e.g. "Monday" → resolved to actual date)
  category  String // "food", "exercise", "symptom", "medication", "sleep", "water", "mood"
  summary   String // concise summary: "Ate sardines for lunch, rice and vegetables for dinner"
  details   Json? // optional structured data: { meals: [...], nutrients: [...] }
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([userId, category])
  @@index([createdAt])
}

/// Admin-editable clinical knowledge base consumed by the AI assistant.
/// Replaces the hardcoded condition→diet mapping that used to live inside
/// `AiService.buildConditionDietaryNotes`. Regional admins can CRUD these
/// rows via the admin UI; `AiService` caches the table in memory and
/// refreshes on edit (or after a 5-min TTL).
///
/// `conditionKey` is the canonical lowercase name ('diabetes', 'hypertension')
/// and `aliases` are additional tokens that should also match user-declared
/// conditions ('diabetic', 'high blood pressure', etc.).
model ClinicalKnowledge {
  id              String   @id @default(uuid())
  conditionKey    String   @unique
  /// Additional case-insensitive tokens that also trigger this guidance.
  aliases         String[]
  /// One-line dietary/wellness guidance injected into the AI system prompt.
  dietaryGuidance String
  /// Bucket for admin-UI grouping: 'nutrition' | 'exercise' | 'mental-health' | 'medication' | 'other'.
  category        String   @default("nutrition")
  /// Free-form references (studies, guidelines) for auditability. Not shown to users.
  sources         String[]
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([active])
  @@index([category])
}

/// Per-call cost + latency + safety telemetry for the AI assistant.
/// Powers the admin cost dashboard and the weekly drift-detection cron.
/// Never read by the user-facing chat — write-only from the service layer.
model AiCallLog {
  id                String   @id @default(cuid())
  userId            String
  surface           String   // 'chat' | 'ocr' | 'insights' | 'tracker_context' | 'emergency-gate'
  model             String   // e.g. 'llama-3.1-8b-instant'
  promptTokens      Int      @default(0)
  completionTokens  Int      @default(0)
  durationMs        Int      @default(0)
  promptVersion     String?
  /// When the emergency gate matched, which category fired.
  emergencyCategory String?
  /// Comma-separated allergens the post-filter caught in the response.
  allergyMatched    String?
  /// Error code (e.g. 'http_429', 'timeout') when the call failed.
  error             String?
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([surface, createdAt])
  @@index([error])
}

// ─── Health Tracker Models ──────────────────────────────────────────────────

model HealthTrackerProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  heightCm           Float?
  weightKg           Float?
  age                Int?
  gender             String?
  activityLevel      ActivityLevel @default(moderately_active)
  weightGoal         WeightGoal    @default(maintain)
  targetCalories     Int?
  targetWaterMl      Int           @default(2000)
  targetExerciseMin  Int           @default(30)
  targetSleepMin     Int           @default(480)
  dietaryPreferences String[]
  allergenSettings   String[]
  tdeeCalories       Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([userId])
}

model FoodEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  time        DateTime
  mealType    MealType
  name        String
  calories    Int
