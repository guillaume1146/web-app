  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime
  caloriesConsumed  Int      @default(0)
  caloriesBurned    Int      @default(0)
  waterConsumedMl   Int      @default(0)
  exerciseMinutes   Int      @default(0)
  targetCalories    Int
  targetWaterMl     Int
  targetExerciseMin Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model MealPlanEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  dayOfWeek     Int
  mealType      MealType
  name          String
  description   String?
  calories      Int
  protein       Float    @default(0)
  carbs         Float    @default(0)
  fat           Float    @default(0)
  isGenerated   Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId, weekStartDate])
  @@index([userId, dayOfWeek])
}

model FoodDatabase {
  id          String  @id @default(cuid())
  name        String
  category    String
  calories    Int
  protein     Float   @default(0)
  carbs       Float   @default(0)
  fat         Float   @default(0)
  fiber       Float   @default(0)
  servingSize String
  unit        String  @default("serving")
  isLocal     Boolean @default(false)

  @@index([category])
  @@index([name])
}

// ─── Generic Provider Reviews ───────────────────────────────────────────────

model ProviderReview {
  id             String    @id @default(uuid())
  providerUserId String
  providerUser   User      @relation("ReviewsReceived", fields: [providerUserId], references: [id], onDelete: Cascade)
  reviewerUserId String
  reviewerUser   User      @relation("ReviewsGiven", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  providerType   String // DOCTOR, NURSE, NANNY, PHARMACIST, LAB_TECHNICIAN, EMERGENCY_WORKER
  rating         Int
  comment        String
  verified       Boolean   @default(false)
  helpfulCount   Int       @default(0)
  response       String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([providerUserId, reviewerUserId, providerType])
  @@index([providerUserId])
  @@index([providerUserId, providerType])
  @@index([providerType])
  @@index([createdAt])
}

// ─── Platform Commission Configuration (singleton) ──────────────────────────

model PlatformConfig {
  id                     String   @id @default(uuid())
  platformCommissionRate Float    @default(15) // % to platform
  regionalCommissionRate Float    @default(0) // % default to regional admin (earns from subscriptions, not transactions)
  providerCommissionRate Float    @default(85) // % to service provider
  currency               String   @default("MUR")
  trialWalletAmount      Float    @default(4500)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── Role Feature Configuration (admin-configurable) ────────────────────────

model RoleFeatureConfig {
  id         String   @id @default(uuid())
  userType   String
  featureKey String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userType, featureKey])
  @@index([userType])
}

// ─── Required Document Configuration (admin-configurable) ───────────────────

model RequiredDocumentConfig {
  id           String   @id @default(uuid())
  userType     String
  documentName String
  required     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userType, documentName])
  @@index([userType])
}

// ─── User Preferences ──────────────────────────────────────────────────────

// ─── Insurance financial plumbing (Health Credit flow) ─────────────────
// Everything denominated in "health credit" (same unit as UserWallet.balance).
// When real-money topup is added later, cash flows INTO PlatformTreasury and
// each user's wallet is just an internal ledger backed by that real balance.

/// Pool holding contributions for one insurance company. Claims pay out
/// of this pool, NOT the owner's personal wallet.
model InsuranceCompanyTreasury {
  id               String   @id @default(uuid())
  companyProfileId String   @unique
  company          CorporateAdminProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  balance          Float    @default(0)
  currency         String   @default("MUR")
  totalInflow      Float    @default(0)
  totalOutflow     Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     TreasuryTransaction[]

  @@index([companyProfileId])
}

model TreasuryTransaction {
  id            String   @id @default(uuid())
  treasuryId    String
  treasury      InsuranceCompanyTreasury @relation(fields: [treasuryId], references: [id], onDelete: Cascade)
  type          TreasuryTxType
  amount        Float    // always positive; `type` disambiguates direction
  memberId      String?
  claimId       String?
  description   String
  balanceBefore Float
  balanceAfter  Float
  createdAt     DateTime @default(now())

  @@index([treasuryId, createdAt])
  @@index([claimId])
}

/// Singleton — MediWyz platform treasury. Receives platform fees on every
/// insurance contribution; later receives top-ups from real-money payment
/// providers (MCB Juice, card). One row, forever.
model PlatformTreasury {
  id        String   @id @default(uuid())
  balance   Float    @default(0)
  currency  String   @default("MUR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Insurance plan / policy structure ─────────────────────────────────

/// One company can offer multiple plans (Basic, Family, Gold) with different
/// ceilings, deductibles, co-pay rates. Members enrol in a plan via policy.
model InsurancePlan {
  id                  String   @id @default(uuid())
  companyProfileId    String
  company             CorporateAdminProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  name                String   // "Basic", "Family", "Gold"
  description         String?
  monthlyContribution Float
  annualCeiling       Float    // max total payout per year per member
  deductible          Float    @default(0)   // annual amount member pays first
  coPayPercent        Float    @default(20)  // member's share of each claim
  waitingPeriodDays   Int      @default(30)
  /// JSON: { "consultation": 2000, "hospitalization": 50000, "dental": 3000 }
  categoryLimits      Json?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  policies            InsurancePolicy[]

  @@index([companyProfileId])
  @@index([isActive])
}

/// An enrolled member's policy. Tracks year-to-date usage for limit rules.
model InsurancePolicy {
  id             String   @id @default(uuid())
  memberId       String
  member         User     @relation("MemberPolicies", fields: [memberId], references: [id], onDelete: Cascade)
  planId         String
  plan           InsurancePlan @relation(fields: [planId], references: [id])
  startDate      DateTime @default(now())
  renewsAt       DateTime
  status         String   @default("active") // active | lapsed | cancelled
  ytdClaimsPaid  Float    @default(0)
  ytdResetAt     DateTime @default(now())
  deductibleUsed Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  beneficiaries  PolicyBeneficiary[]
  renewals       PolicyRenewalLog[]

  @@index([memberId])
  @@index([planId])
  @@index([status])
  @@index([renewsAt])
}

/// Idempotency ledger for insurance-policy monthly renewals. Mirrors the
/// `SubscriptionRenewalLog` pattern: unique (policyId, period) means a
/// double-fired cron (e.g. two nodes in a clustered deploy) tries to INSERT
/// and the second call gets a P2002 — guaranteeing no double-charge.
model PolicyRenewalLog {
  id        String          @id @default(uuid())
  policyId  String
  policy    InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  period    String          // "YYYY-MM"
  amount    Float
  chargedAt DateTime        @default(now())

  @@unique([policyId, period])
  @@index([policyId])
}

model PolicyBeneficiary {
  id           String   @id @default(uuid())
  policyId     String
  policy       InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  name         String
  relationship String // spouse | child | parent | other
  dateOfBirth  DateTime?
  createdAt    DateTime @default(now())

  @@index([policyId])
}

/// Audit trail for every claim decision — which rules fired, what each computed.
/// Reuses the WorkflowStepLog pattern.
model ClaimDecisionLog {
  id           String   @id @default(uuid())
  claimId      String
  decision     String   // approved | denied | pending_review
  payoutAmount Float    @default(0)
  /// Array of { rule, result, message } describing what each rule did
  rulesApplied Json
  reason       String?
  decidedBy    String
  createdAt    DateTime @default(now())

  @@index([claimId])
  @@index([createdAt])
}

/// Pre-authorization for tiers payant (direct billing). A provider asks the
/// insurance company to pre-approve coverage BEFORE delivering a service.
/// If approved, the insurer reserves an amount in the treasury; when the
/// provider marks the authorization `used`, funds flow treasury → provider
/// wallet without the patient touching money.
model PreAuthorization {
  id                String   @id @default(uuid())
  memberId          String
  member            User     @relation("MemberPreAuths", fields: [memberId], references: [id], onDelete: Cascade)
  providerId        String
  provider          User     @relation("ProviderPreAuths", fields: [providerId], references: [id], onDelete: Cascade)
  companyProfileId  String
  company           CorporateAdminProfile @relation("CompanyPreAuths", fields: [companyProfileId], references: [id], onDelete: Cascade)

  serviceCode       String?  // optional PlatformService reference
  category          String?  // consultation | dental | hospitalization ...
  description       String
  requestedAmount   Float
  approvedAmount    Float?
  memberPaysAmount  Float?

  status            String   @default("pending") // pending | approved | denied | used | expired | cancelled
  expiresAt         DateTime
  rulesApplied      Json?
  denialReason      String?

  usedAt            DateTime?
  claimId           String?  // FK to the resulting paid claim

  reviewedAt        DateTime?
  reviewedBy        String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([memberId])
  @@index([providerId])
  @@index([companyProfileId, status])
  @@index([status, expiresAt])
}

// ─── Saved providers (favorites) ───────────────────────────────────────
model ProviderFavorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  provider   User     @relation("ProviderFavoritedBy", fields: [providerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
  @@index([userId])
  @@index([providerId])
}

// ─── Insurance claim submissions (member → owner workflow) ─────────────
model InsuranceClaimSubmission {
  id            String   @id @default(uuid())
  memberId      String
  member        User     @relation("MemberClaims", fields: [memberId], references: [id], onDelete: Cascade)
  companyProfileId String
  company       CorporateAdminProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  description   String
  amount        Float    // requested reimbursement amount (MUR)
  currency      String   @default("MUR")
  receiptUrl    String?
  status        String   @default("pending") // pending, approved, denied, paid
  reviewerNote  String?
  reviewedAt    DateTime?
  reviewedBy    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([memberId])
  @@index([companyProfileId])
  @@index([status])
  @@index([companyProfileId, status])
}

// ─── Health tracker streaks ────────────────────────────────────────────
model HealthStreak {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastCheckInDate String?  // YYYY-MM-DD
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ─── Appointment reminder log (idempotency for cron) ───────────────────
model AppointmentReminder {
  id          String   @id @default(uuid())
  bookingId   String
  bookingType String
  reminderType String  // 't_minus_24h' | 't_minus_1h'
  sentAt      DateTime @default(now())

  @@unique([bookingId, reminderType])
  @@index([bookingId])
}

model UserPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language             String   @default("en") // en, fr, mfe
  timezone             String   @default("Indian/Mauritius")
  emailNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(true)
  smsNotifications     Boolean  @default(false)
  appointmentReminders Boolean  @default(true)
  marketingEmails      Boolean  @default(false)
  profileVisibility    String   @default("public") // public, connections, private
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

// ─── Referral Click Tracking ─────────────────────────────────────────────────

model ReferralClick {
  id                String    @id @default(uuid())
  referralCode      String
  referralPartnerId String? // links to ReferralPartnerProfile.id
  source            String? // alias for utmSource (used by tracking service)
  medium            String? // alias for utmMedium (used by tracking service)
  converted         Boolean   @default(false)
  utmSource         String? // facebook, instagram, linkedin, twitter, whatsapp, email, website, tiktok, youtube
  utmMedium         String? // social, messaging, direct, email
  utmCampaign       String? // campaign identifier
  location          String? // geographic location
  landingPage       String? // which page they landed on
  convertedUserId   String? // null until signup, then linked to User.id
  convertedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([referralCode])
  @@index([referralPartnerId])
  @@index([utmSource])
  @@index([createdAt])
  @@index([convertedUserId])
}

// ─── User Connections ────────────────────────────────────────────────────────

model UserConnection {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("ConnectionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ConnectionsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([receiverId, status])
}

// ─── Subscription Models ──────────────────────────────────────────────────────

model SubscriptionPlan {
  id               String               @id @default(uuid())
  name             String
  slug             String               @unique
  type             SubscriptionPlanType
  price            Float
  currency         String               @default("MUR")
  countryCode      String? // null = global, "MU" = region-specific
  targetAudience   String? // "students & young adults", "families", etc.
  quotas           Json                 @default("[]") // Array of { role: string, specialty?: string, limit: number }
  discounts        Json? // { "DOCTOR:Cardiology": 20, "lab": 15, "pharmacy": 10, "volume_50": 5 }
  paidServices     Json? // services NOT included, with default prices
  features         Json // Array of feature strings
  isActive         Boolean              @default(true)
  createdByAdminId String? // regional admin who created/manages this
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  subscriptions UserSubscription[]
  planServices  SubscriptionPlanService[]
  planPrograms  SubscriptionPlanProgram[]

  @@index([type])
  @@index([isActive])
  @@index([countryCode])
  @@index([countryCode, type])
}

model UserSubscription {
  id               String             @id @default(uuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             SubscriptionPlan   @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(active)
  startDate        DateTime           @default(now())
  endDate          DateTime?
  autoRenew        Boolean            @default(true)
  corporateAdminId String? // If enrolled via company
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  usage    SubscriptionUsage[]
  renewals SubscriptionRenewalLog[]

  @@index([planId])
  @@index([status])
  @@index([corporateAdminId])
}

/// Idempotency ledger for individual-subscription monthly renewals. The cron
/// inserts one row per (subscriptionId, period) — unique constraint makes a
/// double-fire a no-op instead of a double-charge.
model SubscriptionRenewalLog {
  id             String           @id @default(uuid())
  subscriptionId String
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  period         String           // "YYYY-MM"
  amount         Float
  chargedAt      DateTime         @default(now())

  @@unique([subscriptionId, period])
  @@index([subscriptionId])
}

model SubscriptionUsage {
  id             String           @id @default(uuid())
  subscriptionId String
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  month          String // "2026-03"
  usageData      Json             @default("{}") // { "DOCTOR:General Practice": 1, "NURSE": 0 }
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([subscriptionId, month])
  @@index([month])
}

model CorporateEmployee {
  id               String                  @id @default(uuid())
  corporateAdminId String
  corporateAdmin   User                    @relation("CorporateAdminUser", fields: [corporateAdminId], references: [id], onDelete: Cascade)
  userId           String
  user             User                    @relation("EmployeeUser", fields: [userId], references: [id], onDelete: Cascade)
  status           CorporateEmployeeStatus @default(pending)
  department       String?
  joinedAt         DateTime                @default(now())
  approvedAt       DateTime?
  removedAt        DateTime?

  // Insurance contribution tracking — null if company is not an insurance co.
  // Stores ISO "YYYY-MM" of the last paid period + timestamp of last payment.
  lastContributionMonth String?
  lastContributionAt    DateTime?

  @@unique([corporateAdminId, userId])
  @@index([corporateAdminId])
  @@index([userId])
  @@index([status])
  @@index([lastContributionMonth])
}

// ─── Platform Service Catalog (unified service definitions) ─────────────────

model PlatformService {
  id                  String   @id @default(uuid())
  providerType        UserType // DOCTOR, NURSE, NANNY, PHARMACIST, LAB_TECHNICIAN, EMERGENCY_WORKER
  serviceName         String
  category            String // Consultation, Screening, Wound Care, etc.
  description         String
  iconKey             String? // Iconify format: "healthicons:stethoscope", "ph:syringe-duotone", etc.
  emoji               String? // Fallback emoji character (e.g. "🩺", "💊")
  imageUrl            String? // Custom uploaded illustration (takes priority over emoji/iconKey)
  defaultPrice        Float    @default(0)
  currency            String   @default("MUR")
  duration            Int? // minutes
  isDefault           Boolean  @default(true) // true = auto-assigned to new providers on registration
  countryCode         String? // null = all regions, "MU" = region-specific
  createdByProviderId String? // null = platform default; set = provider-created custom service
  requiredContentType String? // Auto-require content on booking completion (e.g., "lab_result", "dental_chart", "meal_plan")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  providerConfigs   ProviderServiceConfig[]
  planServices      SubscriptionPlanService[]
  groupItems        ServiceGroupItem[]
  workflowTemplates WorkflowTemplate[]

  @@index([providerType])
  @@index([providerType, serviceName])
  @@index([category])
  @@index([countryCode])
  @@index([isDefault])
}

// ─── Provider Service Config (provider's instance + price override) ──────────

model ProviderServiceConfig {
  id                String          @id @default(uuid())
  platformServiceId String
  platformService   PlatformService @relation(fields: [platformServiceId], references: [id], onDelete: Cascade)
  providerUserId    String // User ID of the provider
  priceOverride     Float? // null = use admin/default price; set = provider's custom price
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Workflow templates explicitly attached by the provider when they offer this service
  workflowTemplates ProviderServiceWorkflow[]

  @@unique([platformServiceId, providerUserId])
  @@index([providerUserId])
  @@index([platformServiceId])
}

// Join table: which workflow templates a provider offers for a specific service
model ProviderServiceWorkflow {
  id                      String                @id @default(uuid())
  providerServiceConfigId String
  providerServiceConfig   ProviderServiceConfig @relation(fields: [providerServiceConfigId], references: [id], onDelete: Cascade)
  workflowTemplateId      String
  workflowTemplate        WorkflowTemplate      @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  createdAt               DateTime              @default(now())

  @@unique([providerServiceConfigId, workflowTemplateId])
  @@index([providerServiceConfigId])
  @@index([workflowTemplateId])
}

// ─── Service Groups (regional admin groups services for plans) ───────────────

model ServiceGroup {
  id               String   @id @default(uuid())
  name             String
  description      String?
  countryCode      String
  createdByAdminId String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items        ServiceGroupItem[]
  planServices SubscriptionPlanService[]

  @@index([countryCode])
  @@index([createdByAdminId])
}

// ─── Service Group Items (services within a group) ──────────────────────────

model ServiceGroupItem {
  id                String          @id @default(uuid())
  serviceGroupId    String
  serviceGroup      ServiceGroup    @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  platformServiceId String
  platformService   PlatformService @relation(fields: [platformServiceId], references: [id], onDelete: Cascade)

  @@unique([serviceGroupId, platformServiceId])
  @@index([serviceGroupId])
  @@index([platformServiceId])
}

// ─── Subscription Plan Services (links plans to services/groups) ────────────

model SubscriptionPlanService {
  id                String           @id @default(uuid())
  planId            String
  plan              SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  platformServiceId String? // direct service link
  platformService   PlatformService? @relation(fields: [platformServiceId], references: [id], onDelete: Cascade)
  serviceGroupId    String? // OR a service group link
  serviceGroup      ServiceGroup?    @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  isFree            Boolean          @default(false) // true = included free in plan
  discountPercent   Int              @default(0) // % discount off provider's market price (0-100)
  adminPrice        Float? // admin-set fixed price (overrides discount); null = use default
  monthlyLimit      Int              @default(0) // -1 = unlimited, 0 = pay-per-use, N = N per month

  @@index([planId])
  @@index([platformServiceId])
  @@index([serviceGroupId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKFLOW ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

enum PaymentTiming {
  IMMEDIATE      // Charge at booking creation
  ON_ACCEPTANCE  // Charge when provider accepts
  ON_COMPLETION  // Charge when booking completes
  PAY_LATER      // No automatic charge (manual billing)
}

enum WorkflowSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Workflow Step Type Library (pre-built step atoms with default flags) ─────

model WorkflowStepType {
  code        String  @id // VIDEO_CALL_READY, CONFIRMED, etc.
  label       String  // "Video Call Ready"
  description String? // plain language explanation
  category    String  // consultation, home_visit, lab, delivery, emergency, generic

  // Default flags that the engine applies when this stepType is used
  defaultFlags           Json @default("{}") // { triggers_video_call, requires_content, … }
  defaultActionsProvider Json @default("[]") // default button definitions for provider
  defaultActionsPatient  Json @default("[]") // default button definitions for patient

  isTerminal     Boolean @default(false) // completed / cancelled terminal states
  isCancellation Boolean @default(false) // specifically a cancellation step
  sortOrder      Int     @default(100) // display order in pickers

  createdAt DateTime @default(now())
}

// ─── Workflow Template (defines steps, transitions, notifications per service+mode) ─

model WorkflowTemplate {
  id           String  @id @default(uuid())
  name         String // "Doctor Consultation - Office"
  slug         String  @unique // "doctor-consultation-office"
  description  String?
  providerType String // DOCTOR, NURSE, DENTIST, etc.
  serviceMode  String // office, home, video
  isDefault    Boolean @default(false) // system seed = true
  isActive     Boolean @default(true)
  isLibrary    Boolean @default(false) // true = appears in the "Start from template" picker for admins
  isBundle     Boolean @default(false) // true = complete pre-built template ready to use
  category     String? // loose grouping: 'Consultation', 'Home Visit', 'Lab', 'Delivery', 'Emergency'

  paymentTiming PaymentTiming @default(ON_ACCEPTANCE)

  // Provider suggestion flow
  suggestedByProviderId String?
  suggestionStatus      WorkflowSuggestionStatus?
  suggestionNote        String? // reviewer note on approval/rejection
  suggestedAt           DateTime?

  // Ownership — null = system default
  createdByProviderId String? // provider custom workflow
  createdByAdminId    String? // regional admin default
  regionCode          String? // null = global, "MU" = Mauritius only

  // Link to service catalog
  platformServiceId String?
  platformService   PlatformService? @relation(fields: [platformServiceId], references: [id], onDelete: SetNull)

  // Steps definition (ordered JSON array)
  // Each: { order, statusCode, label, description,
  //         actionsForPatient: [{ action, label, targetStatus, style }],
  //         actionsForProvider: [{ action, label, targetStatus, style }],
  //         flags: { triggers_video_call?, triggers_stock_check?,
  //                  triggers_stock_subtract?, requires_prescription?,
  //                  requires_content? },
  //         notifyPatient?: { title, message },
  //         notifyProvider?: { title, message } }
  steps Json

  // Allowed transitions (JSON array)
  // Each: { from, to, action, allowedRoles: ["patient"|"provider"|"system"],
  //         conditions?: { requiresPayment?, requiresPrescription? } }
  transitions Json

  // SLA & operational metadata
  expectedDurationHours Int?    // expected hours to complete end-to-end
  slaNote               String? // human note about SLA expectations / guarantees

  // Cross-region sharing (admin can mark a template shareable so other regions can clone it)
  isShared Boolean @default(false)

  // Snapshot history: array of { snapshotAt, changedBy, steps, transitions }
  stepsHistory Json @default("[]")

  // ─── Service-level systematic configuration ────────────────────────────────
  // A free-form JSON object so new workflow behaviours can be added by writing
  // a new Strategy class — no DB column or migration needed.
  //
  // Recognised shape (see WorkflowServiceConfig in types.ts):
  //   {
  //     "preflight": {
  //       "requires": ["db:prescription", "input:lab_result", "input:dental_chart"]
  //       // "db:<type>" → check existing DB record;  "input:<type>" → require in transition input
  //     },
  //     "onComplete": {
  //       "actions": ["subtract_stock"]
  //       // list of action keys handled by registered StepFlagHandler executors
  //     }
  //   }
  //
  // All three lifecycle hooks fire regardless of step position:
  //   preflight.requires  → blocks any accept/confirm/approve if not satisfied
  //   onComplete.actions  → auto-executes when the workflow reaches a terminal success state
  serviceConfig Json @default("{}")

  instances             WorkflowInstance[]
  notificationTemplates WorkflowNotificationTemplate[]
  providerServiceLinks  ProviderServiceWorkflow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerType, serviceMode])
  @@index([platformServiceId])
  @@index([createdByProviderId])
  @@index([createdByAdminId])
  @@index([isDefault])
  @@index([isShared])
}

// ─── Workflow Instance (tracks one booking's progress through a template) ────

model WorkflowInstance {
  id         String           @id @default(uuid())
  templateId String
  template   WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Polymorphic booking reference
  bookingId   String
  bookingType String // appointment, nurse_booking, childcare_booking, lab_test_booking, emergency_booking, service_booking

  currentStatus  String // current step statusCode
  previousStatus String?

  patientUserId  String
  providerUserId String

  serviceMode String // office, home, video

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  metadata Json? // extra data per instance

  /// Snapshot of the template at instance creation. Guards against a
  /// regional admin editing the template mid-flight: the engine reads
  /// steps / transitions / notifications from this snapshot when present,
  /// falling back to the live `template` relation for old instances that
  /// pre-date the snapshot field. Populated by
  /// `WorkflowEngine.attachWorkflow()`.
  templateSnapshot Json?

  steps WorkflowStepLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId, bookingType])
  @@index([patientUserId])
  @@index([providerUserId])
  @@index([currentStatus])
  @@index([templateId])
}

// ─── Workflow Step Log (audit trail: every status change recorded) ───────────

model WorkflowStepLog {
  id         String           @id @default(uuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  fromStatus     String? // null for first step
  toStatus       String
  action         String // "accept", "start_care", "complete", etc.
  actionByUserId String
  actionByRole   String // "patient", "provider", "system"

  // Display
  label   String // "Consultation en cours"
  message String? // detailed message

  // Content attachment (prescription, lab results, care notes, etc.)
  contentType String? // "prescription", "lab_result", "care_notes", "report", "dental_chart", "eye_prescription", "meal_plan", "exercise_plan"
  contentData Json? // { medications: [...] } or { findings: "...", values: [...] }

  // Triggered actions results
  triggeredVideoCallId  String? // if video call was created
  triggeredStockActions Json? // [{ itemId, qty, action: "check"|"subtract" }]

  // Notification tracking
  notificationId String? // Notification.id that was created

  createdAt DateTime @default(now())

  @@index([instanceId])
  @@index([toStatus])
  @@index([createdAt])
}

// ─── Workflow Notification Template (custom notification messages per step) ──

model WorkflowNotificationTemplate {
  id                 String           @id @default(uuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)

  statusCode       String // which step this notification is for
  targetRole       String // "patient" or "provider"
  title            String // supports {{variables}} like {{patientName}}, {{providerName}}
  message          String // supports {{variables}}
  notificationType String @default("workflow") // notification type code

  // Ownership (null = system default)
  createdByProviderId String?
  createdByAdminId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowTemplateId, statusCode, targetRole, createdByProviderId])
  @@index([workflowTemplateId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROVIDER INVENTORY (generalized from PharmacyMedicine — all providers can sell)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Provider Inventory Item (any provider, not just pharmacist) ─────────────

model ProviderInventoryItem {
  id             String @id @default(uuid())
  providerUserId String // any provider's User.id
  providerType   String // PHARMACIST, OPTOMETRIST, DENTIST, NANNY, etc.

  // Product info
  name        String
  genericName String? // for medicines
  category    String // "medication", "equipment", "accessory", "supply", "eyewear", etc.
  description String?
  imageUrl    String?

  // Measurement
  unitOfMeasure String  @default("unit") // unit, box, bottle, pair, ml, mg, kg
  strength      String? // "500mg" for medicines
  dosageForm    String? // tablet, capsule, syrup, etc. (medicines only)

  // Pricing
  price           Float
  currency        String @default("MUR")
  discountPercent Float? // optional discount

  // Stock
  quantity      Int     @default(0)
  minStockAlert Int     @default(5) // alert when stock <= this
  inStock       Boolean @default(true)

  // Flags
  requiresPrescription Boolean @default(false) // medicines needing Rx
  isActive             Boolean @default(true)
  isFeatured           Boolean @default(false) // show in Health Shop highlights

  // Medicine-specific (nullable for non-medicines)
  sideEffects String[]  @default([])
  expiryDate  DateTime?

  // Relations
  orderItems InventoryOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerUserId])
  @@index([providerType, category])
  @@index([category])
  @@index([inStock])
  @@index([name])
}

// ─── Inventory Order (patient orders from any provider's inventory) ──────────

model InventoryOrder {
  id             String @id @default(uuid())
  patientUserId  String
  providerUserId String
  providerType   String

  status String @default("pending") // pending, confirmed, preparing, ready_for_pickup, ready_for_delivery, delivery_in_progress, delivered, picked_up, completed, cancelled

  totalAmount     Float
  currency        String  @default("MUR")
  deliveryType    String? // pickup, delivery
  deliveryAddress String?
  deliveryFee     Float   @default(0)

  // Prescription
  prescriptionRequired Boolean @default(false)
  prescriptionId       String? // reference to uploaded prescription

  // Workflow
  workflowInstanceId String? // linked workflow for order tracking

  items InventoryOrderItem[]

  orderedAt   DateTime  @default(now())
  confirmedAt DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([providerUserId])
  @@index([status])
}

// ─── Inventory Order Item (line items with quantity and pricing) ─────────────

model InventoryOrderItem {
  id              String                @id @default(uuid())
  orderId         String
  order           InventoryOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   ProviderInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  quantity   Int
  unitPrice  Float
  totalPrice Float

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([inventoryItemId])
}

// ─── Healthcare Entity (clinic, hospital, pharmacy chain, lab, etc.) ──────────
// Represents a physical or virtual institution that providers work at.
// Many providers can belong to many entities (join via ProviderWorkplace).

model HealthcareEntity {
  id          String  @id @default(uuid())
  name        String
  type        String  // clinic, hospital, pharmacy, laboratory, wellness_center, dental_clinic, optical_center, other
  description String?
  address     String?
  city        String?
  country     String  @default("MU") // ISO-2 country code
  regionId    String?
  phone       String?
  email       String?
  website     String?
  logoUrl     String?

  // Geo coordinates for nearest-clinic search (future GPS integration)
  latitude    Float?
  longitude   Float?

  isVerified  Boolean @default(false)
  isActive    Boolean @default(true)

  // Founder — the user who created/manages this entity
  founderUserId String?
  founder       User?   @relation("EntityFounder", fields: [founderUserId], references: [id], onDelete: SetNull)

  // Providers affiliated with this entity
  providers     ProviderWorkplace[]
  invitations   WorkplaceInvitation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, city, country])
  @@index([type])
  @@index([city, country])
  @@index([isActive])
  @@index([founderUserId])
}

// ─── Provider Workplace (many-to-many: provider ↔ HealthcareEntity) ──────────

model ProviderWorkplace {
  id                 String          @id @default(uuid())
  providerUserId     String
  provider           User            @relation(fields: [providerUserId], references: [id], onDelete: Cascade)
  healthcareEntityId String
  entity             HealthcareEntity @relation(fields: [healthcareEntityId], references: [id], onDelete: Cascade)

  role               String?  // e.g. "Senior Consultant", "Visiting Physician"
  isPrimary          Boolean  @default(false)
  isActive           Boolean  @default(true)
  // pending_approval = employee requested to join (founder must approve)
  // active           = confirmed member
  // rejected         = founder rejected the request
  status             String   @default("active")

  startDate          DateTime?
  endDate            DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([providerUserId, healthcareEntityId])
  @@index([providerUserId])
  @@index([healthcareEntityId])
  @@index([status])
}

// ─── Workplace Invitation (founder invites provider by email) ─────────────────

model WorkplaceInvitation {
  id                 String          @id @default(uuid())
  healthcareEntityId String
  entity             HealthcareEntity @relation(fields: [healthcareEntityId], references: [id], onDelete: Cascade)
  invitedByUserId    String
  invitedBy          User            @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedEmail       String          // email the invite was sent to
  suggestedRole      String?         // founder can suggest a role
  token              String          @unique @default(uuid())
  // pending, accepted, rejected, expired
  status             String          @default("pending")
  expiresAt          DateTime
  acceptedByUserId   String?         // set when the invited user accepts

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([healthcareEntityId])
  @@index([invitedEmail])
  @@index([token])
  @@index([status])
}
