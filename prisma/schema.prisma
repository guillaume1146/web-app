generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Type Enum ──────────────────────────────────────────────────────────

enum UserType {
  PATIENT
  DOCTOR
  NURSE
  NANNY
  PHARMACIST
  LAB_TECHNICIAN
  EMERGENCY_WORKER
  INSURANCE_REP
  CORPORATE_ADMIN
  REFERRAL_PARTNER
  REGIONAL_ADMIN
  CAREGIVER
  PHYSIOTHERAPIST
  DENTIST
  OPTOMETRIST
  NUTRITIONIST
}

// ─── Booking & Appointment Status Enums ────────────────────────────────────

enum BookingStatus {
  pending
  upcoming
  confirmed
  completed
  cancelled
}

enum AppointmentType {
  video
  in_person
  home_visit
}

enum EmergencyStatus {
  pending
  dispatched
  en_route
  resolved
  cancelled
}

enum Priority {
  low
  medium
  high
  critical
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
  extra_active
}

enum WeightGoal {
  lose
  maintain
  gain
}

enum ExerciseIntensity {
  light
  moderate
  vigorous
}

enum SubscriptionPlanType {
  individual
  corporate
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}

enum CorporateEmployeeStatus {
  pending
  active
  removed
}

// ─── Region Model ────────────────────────────────────────────────────────────

model Region {
  id             String   @id @default(uuid())
  name           String   @unique
  countryCode    String   @unique
  language       String   @default("en")
  flag           String?
  currency       String   @default("MUR")
  currencySymbol String   @default("Rs")
  trialCredit    Float    @default(4500)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
}

// ─── Base User Model (auth + shared fields) ──────────────────────────────────

model User {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String    @unique
  password       String
  profileImage   String?
  phone          String
  userType       UserType
  dateOfBirth    DateTime?
  gender         String?
  address        String?
  verified       Boolean   @default(false)
  accountStatus  String    @default("active") // active, suspended, pending
  referredByCode String? // Referral code used at signup
  regionId       String?
  region         Region?   @relation(fields: [regionId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 1:1 optional profile relations (only one will be non-null per user)
  patientProfile         PatientProfile?
  doctorProfile          DoctorProfile?
  nurseProfile           NurseProfile?
  nannyProfile           NannyProfile?
  pharmacistProfile      PharmacistProfile?
  labTechProfile         LabTechProfile?
  emergencyWorkerProfile EmergencyWorkerProfile?
  insuranceRepProfile    InsuranceRepProfile?
  corporateAdminProfile  CorporateAdminProfile?
  referralPartnerProfile ReferralPartnerProfile?
  regionalAdminProfile      RegionalAdminProfile?
  caregiverProfile          CaregiverProfile?
  physiotherapistProfile    PhysiotherapistProfile?
  dentistProfile            DentistProfile?
  optometristProfile        OptometristProfile?
  nutritionistProfile       NutritionistProfile?

  // Cross-cutting relations (generic for all user types)
  videoCallSessions    VideoCallSession[]
  conversations        ConversationParticipant[]
  sentMessages         Message[]
  notifications        Notification[]
  billingInfo          BillingInfo[]
  documents            Document[]
  wallet               UserWallet?
  providerAvailability ProviderAvailability[]

  // Social / posts relations
  posts        DoctorPost[]  @relation("PostAuthor")
  postComments PostComment[] @relation("CommentAuthor")
  postLikes    PostLike[]    @relation("PostLiker")

  // AI Chat relations
  aiChatSessions    AiChatSession[]
  aiPatientInsights AiPatientInsight[]

  // Health Tracker relations
  healthTrackerProfile HealthTrackerProfile?
  foodEntries          FoodEntry[]
  exerciseEntries      ExerciseEntry[]
  waterEntries         WaterEntry[]
  sleepEntries         SleepEntry[]
  dailyGoalSnapshots   DailyGoalSnapshot[]
  mealPlanEntries      MealPlanEntry[]

  // Provider reviews
  reviewsReceived ProviderReview[] @relation("ReviewsReceived")
  reviewsGiven    ProviderReview[] @relation("ReviewsGiven")

  // Connection relations
  connectionsSent     UserConnection[] @relation("ConnectionsSent")
  connectionsReceived UserConnection[] @relation("ConnectionsReceived")

  // Preferences
  preferences UserPreference?

  // Subscription
  subscription         UserSubscription?
  corporateEmployments CorporateEmployee[] @relation("EmployeeUser")
  corporateEnrollments CorporateEmployee[] @relation("CorporateAdminUser")

  @@index([email])
  @@index([userType])
  @@index([verified, accountStatus])
  @@index([regionId])
}

// ─── Profile Tables (type-specific fields only) ─────────────────────────────

model PatientProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nationalId        String   @unique
  passportNumber    String?
  bloodType         String
  allergies         String[]
  chronicConditions String[]
  healthScore       Int      @default(50)

  // Patient-specific relations
  emergencyContact  PatientEmergencyContact?
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  vitalSigns        VitalSigns[]
  appointments      Appointment[]
  childcareBookings ChildcareBooking[]
  nurseBookings     NurseBooking[]
  pillReminders     PillReminder[]
  emergencyServices EmergencyServiceContact[]
  nutritionAnalyses NutritionAnalysis[]
  labTests          LabTest[]
  medicineOrders    MedicineOrder[]
  labTestBookings   LabTestBooking[]
  emergencyBookings EmergencyBooking[]
  insuranceClaims   InsuranceClaim[]

  @@index([userId])
}

model DoctorProfile {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty                String[] // e.g. ["General Practice", "Family Medicine"] — GP is just a specialty
  subSpecialties           String[]
  licenseNumber            String    @unique
  licenseExpiryDate        DateTime
  clinicAffiliation        String
  hospitalPrivileges       String[]
  rating                   Float     @default(0)
  reviewCount              Int       @default(0)
  experience               String
  publications             String[]
  awards                   String[]
  location                 String
  alternatePhone           String?
  website                  String?
  languages                String[]
  nextAvailable            DateTime?
  consultationDuration     Int       @default(30)
  consultationFee          Float
  videoConsultationFee     Float
  emergencyConsultationFee Float
  consultationTypes        String[] // video, in-person, home-visit
  emergencyAvailable       Boolean   @default(false)
  homeVisitAvailable       Boolean   @default(false)
  telemedicineAvailable    Boolean   @default(true)
  nationality              String?
  bio                      String
  philosophy               String?
  specialInterests         String[]
  verificationDate         DateTime?

  // Doctor-specific relations
  education       DoctorEducation[]
  certifications  DoctorCertification[]
  workHistory     DoctorWorkHistory[]
  patientComments PatientComment[]
  scheduleSlots   ScheduleSlot[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]
  services        DoctorServiceCatalog[]

  @@index([userId])
}

model DoctorServiceCatalog {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceName String
  category    String // Consultation, Surgery, Screening, Therapy, Procedure, etc.
  description String
  price       Float
  currency    String        @default("MUR")
  duration    Int           @default(30) // minutes
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([doctorId])
  @@index([category])
}

model NurseProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int
  specializations String[]

  // Nurse-specific relations
  nurseBookings       NurseBooking[]
  nurseServiceCatalog NurseServiceCatalog[]

  @@index([userId])
}

model NannyProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience     Int
  certifications String[]

  // Nanny-specific relations
  childcareBookings   ChildcareBooking[]
  nannyServiceCatalog NannyServiceCatalog[]

  @@index([userId])
}

model PharmacistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  pharmacyName    String
  pharmacyAddress String
  specializations String[]

  medicines PharmacyMedicine[]

  @@index([userId])
}

model LabTechProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  labName         String
  specializations String[]

  labTestCatalog  LabTestCatalog[]
  labTestBookings LabTestBooking[]

  @@index([userId])
}

model EmergencyWorkerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications String[]
  vehicleType    String? // ambulance, helicopter, motorcycle
  responseZone   String?
  emtLevel       String? // EMT-Basic, EMT-Intermediate, Paramedic

  serviceListings   EmergencyServiceListing[]
  emergencyBookings EmergencyBooking[]

  @@index([userId])
}

model InsuranceRepProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  licenseNumber String?
  coverageTypes String[] // health, dental, vision, life

  planListings    InsurancePlanListing[]
  insuranceClaims InsuranceClaim[]

  @@index([userId])
}

model CorporateAdminProfile {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  registrationNumber String?
  employeeCount      Int?
  industry           String?

  @@index([userId])
}

model ReferralPartnerProfile {
  id             String @id @default(uuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessType   String
  commissionRate Float  @default(0)
  referralCode   String @unique
  totalReferrals Int    @default(0)

  @@index([userId])
}

model RegionalAdminProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  region          String
  country         String
  countryCode     String?
  commissionRate  Float   @default(10) // % of each transaction
  totalCommission Float   @default(0) // accumulated earnings

  @@index([userId])
  @@index([countryCode])
}

// ─── New Provider Profile Tables ─────────────────────────────────────────────

model CaregiverProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String?
  experience      Int      @default(0)
  specializations String[] // Elder Care, Disability Care, Dementia Care, etc.
  certifications  String[]

  @@index([userId])
}

model PhysiotherapistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // Orthopedic, Neurological, Sports, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model DentistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // General, Orthodontics, Periodontics, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model OptometristProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // General Eye Care, Pediatric, Contact Lenses, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model NutritionistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String?
  experience      Int      @default(0)
  specializations String[] // Clinical, Sports, Pediatric, Weight Management, etc.
  certifications  String[]

  @@index([userId])
}

// ─── Provider Specialties (database-driven, not hardcoded) ──────────────────

model ProviderSpecialty {
  id           String   @id @default(uuid())
  providerType UserType
  name         String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([providerType, name])
  @@index([providerType])
}

// ─── Health Programs ────────────────────────────────────────────────────────

model HealthProgram {
  id                String    @id @default(uuid())
  name              String
  description       String
  providerType      UserType
  specialty         String?
  durationWeeks     Int
  startDate         DateTime?
  endDate           DateTime?
  price             Float
  currency          String    @default("MUR")
  maxParticipants   Int?
  countryCode       String?
  isActive          Boolean   @default(true)
  createdByUserId   String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions    ProgramSession[]
  providers   ProgramProvider[]
  enrollments ProgramEnrollment[]
  planLinks   SubscriptionPlanProgram[]

  @@index([providerType])
  @@index([countryCode])
  @@index([createdByUserId])
  @@index([isActive])
}

model ProgramSession {
  id          String        @id @default(uuid())
  programId   String
  program     HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  weekNumber  Int
  serviceName String
  description String?
  duration    Int?
  sortOrder   Int           @default(0)

  progress ProgramSessionProgress[]

  @@index([programId])
}

model ProgramProvider {
  id        String        @id @default(uuid())
  programId String
  program   HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId    String
  role      String        @default("collaborator") // lead, collaborator
  joinedAt  DateTime      @default(now())

  @@unique([programId, userId])
  @@index([programId])
}

model ProgramEnrollment {
  id          String        @id @default(uuid())
  programId   String
  program     HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  patientId   String
  status      String        @default("enrolled") // enrolled, in_progress, completed, dropped
  enrolledAt  DateTime      @default(now())
  completedAt DateTime?

  sessionProgress ProgramSessionProgress[]

  @@unique([programId, patientId])
  @@index([programId])
  @@index([patientId])
}

model ProgramSessionProgress {
  id           String            @id @default(uuid())
  enrollmentId String
  enrollment   ProgramEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sessionId    String
  session      ProgramSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status       String            @default("pending") // pending, scheduled, completed, missed
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  bookingId    String?

  @@unique([enrollmentId, sessionId])
  @@index([enrollmentId])
}

// ─── Subscription Plan Programs ─────────────────────────────────────────────

model SubscriptionPlanProgram {
  id              String           @id @default(uuid())
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  programId       String
  program         HealthProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  isFree          Boolean          @default(false)
  discountPercent Int              @default(0)

  @@unique([planId, programId])
  @@index([planId])
}

// ─── Clinical Models ─────────────────────────────────────────────────────────

model MedicalRecord {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      DoctorProfile? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  title       String
  date        DateTime
  type        String // consultation, prescription, lab_result, imaging, vaccination, surgery
  summary     String
  diagnosis   String?
  treatment   String?
  notes       String?
  attachments String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([type])
}

model Prescription {
  id         String         @id @default(uuid())
  patientId  String
  patient    PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  date       DateTime       @default(now())
  diagnosis  String
  isActive   Boolean        @default(true)
  nextRefill DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  medicines     PrescriptionMedicine[]
  pillReminders PillReminder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([isActive])
  @@index([date])
}

model Medicine {
  id          String  @id @default(uuid())
  name        String  @unique
  category    String
  description String?

  prescriptionMedicines PrescriptionMedicine[]
  orderItems            MedicineOrderItem[]
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  @@unique([prescriptionId, medicineId])
}

model VitalSigns {
  id               String         @id @default(uuid())
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedAt       DateTime       @default(now())
  systolicBP       Int?
  diastolicBP      Int?
  heartRate        Int?
  temperature      Float?
  weight           Float?
  height           Float?
  oxygenSaturation Int?
  glucose          Int?
  cholesterol      Int?
  facility         String?
  recordedBy       String?
  createdAt        DateTime       @default(now())

  @@index([patientId])
  @@index([recordedAt])
}

model LabTest {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testName    String
  category    String
  orderedAt   DateTime       @default(now())
  completedAt DateTime?
  status      String         @default("pending") // pending, in_progress, completed
  facility    String?
  orderedBy   String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  results LabTestResult[]

  @@index([patientId])
  @@index([status])
  @@index([orderedAt])
}

model LabTestResult {
  id           String  @id @default(uuid())
  labTestId    String
  labTest      LabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  parameter    String
  value        String
  unit         String?
  referenceMin String?
  referenceMax String?
  isAbnormal   Boolean @default(false)

  @@index([labTestId])
}

// ─── Scheduling Models ──────────────────────────────────────────────────────

model Appointment {
  id                 String         @id @default(uuid())
  patientId          String
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId           String
  doctor             DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  scheduledAt        DateTime
  type               String // video, in-person
  status             String         @default("pending") // pending, upcoming, completed, cancelled
  specialty          String
  reason             String
  duration           Int            @default(30)
  location           String?
  roomId             String?
  notes              String?
  cancellationReason String?
  cancelledBy        String?
  cancelledAt        DateTime?
  serviceName        String?
  servicePrice       Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([doctorId, patientId])
  @@index([doctorId, scheduledAt])
  @@index([status, scheduledAt])
}

model ScheduleSlot {
  id        String        @id @default(uuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sunday, 6=Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean       @default(true)

  @@unique([doctorId, dayOfWeek, startTime])
  @@index([doctorId])
}

model NurseBooking {
  id           String         @id @default(uuid())
  patientId    String
  patient      PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurseId      String
  nurse        NurseProfile   @relation(fields: [nurseId], references: [id], onDelete: Restrict)
  scheduledAt  DateTime
  duration     Int
  type         String // in_person, home_visit, video
  status       String         @default("pending") // pending, upcoming, completed, cancelled
  reason       String?
  notes        String?
  serviceName  String?
  servicePrice Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([patientId])
  @@index([nurseId])
  @@index([scheduledAt])
  @@index([status])
}

model ChildcareBooking {
  id                  String         @id @default(uuid())
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nannyId             String
  nanny               NannyProfile   @relation(fields: [nannyId], references: [id], onDelete: Restrict)
  scheduledAt         DateTime
  duration            Int
  type                String // in_person, home_visit, video
  children            String[]
  specialInstructions String?
  reason              String?
  serviceName         String?
  servicePrice        Float?
  status              String         @default("pending") // pending, upcoming, completed, cancelled
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([patientId])
  @@index([nannyId])
  @@index([scheduledAt])
  @@index([status])
}

// ─── WebRTC / Video Call Models ─────────────────────────────────────────────

model VideoRoom {
  id              String   @id @default(uuid())
  roomCode        String   @unique
  name            String?
  creatorId       String // User who created the room
  status          String   @default("active") // active, ended
  maxParticipants Int      @default(2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions     VideoCallSession[]
  participants VideoRoomParticipant[]

  @@index([roomCode])
  @@index([creatorId])
  @@index([status])
}

model VideoRoomParticipant {
  id       String    @id @default(uuid())
  roomId   String
  room     VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  role     String    @default("participant") // host, participant
  joinedAt DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model VideoCallSession {
  id          String    @id @default(uuid())
  roomId      String
  room        VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  duration    Int?
  callQuality String? // poor, fair, good, excellent
  status      String    @default("active") // active, ended, failed
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  connections WebRTCConnection[]

  @@index([roomId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model WebRTCConnection {
  id              String           @id @default(uuid())
  sessionId       String
  session         VideoCallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  userName        String
  socketId        String?
  connectionState String           @default("new") // new, connecting, connected, disconnected, failed
  iceState        String?
  signalData      Json?
  lastSeen        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
