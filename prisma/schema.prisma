generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Type Enum ──────────────────────────────────────────────────────────

enum UserType {
  PATIENT
  DOCTOR
  NURSE
  NANNY
  PHARMACIST
  LAB_TECHNICIAN
  EMERGENCY_WORKER
  INSURANCE_REP
  CORPORATE_ADMIN
  REFERRAL_PARTNER
  REGIONAL_ADMIN
}

// ─── Booking & Appointment Status Enums ────────────────────────────────────

enum BookingStatus {
  pending
  upcoming
  confirmed
  completed
  cancelled
}

enum AppointmentType {
  video
  in_person
  home_visit
}

enum EmergencyStatus {
  pending
  dispatched
  en_route
  resolved
  cancelled
}

enum Priority {
  low
  medium
  high
  critical
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
  extra_active
}

enum WeightGoal {
  lose
  maintain
  gain
}

enum ExerciseIntensity {
  light
  moderate
  vigorous
}

// ─── Region Model ────────────────────────────────────────────────────────────

model Region {
  id          String   @id @default(uuid())
  name        String   @unique
  countryCode String   @unique
  language    String   @default("en")
  flag        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

// ─── Base User Model (auth + shared fields) ──────────────────────────────────

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  email         String    @unique
  password      String
  profileImage  String?
  phone         String
  userType      UserType
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  verified      Boolean   @default(false)
  accountStatus  String    @default("active") // active, suspended, pending
  referredByCode String?   // Referral code used at signup
  regionId       String?
  region         Region?   @relation(fields: [regionId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 1:1 optional profile relations (only one will be non-null per user)
  patientProfile         PatientProfile?
  doctorProfile          DoctorProfile?
  nurseProfile           NurseProfile?
  nannyProfile           NannyProfile?
  pharmacistProfile      PharmacistProfile?
  labTechProfile         LabTechProfile?
  emergencyWorkerProfile EmergencyWorkerProfile?
  insuranceRepProfile    InsuranceRepProfile?
  corporateAdminProfile  CorporateAdminProfile?
  referralPartnerProfile ReferralPartnerProfile?
  regionalAdminProfile   RegionalAdminProfile?

  // Cross-cutting relations (generic for all user types)
  videoCallSessions VideoCallSession[]
  conversations     ConversationParticipant[]
  sentMessages      Message[]
  notifications     Notification[]
  billingInfo       BillingInfo[]
  documents         Document[]
  wallet            UserWallet?
  providerAvailability ProviderAvailability[]

  // Social / posts relations
  posts             DoctorPost[]   @relation("PostAuthor")
  postComments      PostComment[]  @relation("CommentAuthor")
  postLikes         PostLike[]     @relation("PostLiker")

  // AI Chat relations
  aiChatSessions    AiChatSession[]
  aiPatientInsights AiPatientInsight[]

  // Health Tracker relations
  healthTrackerProfile  HealthTrackerProfile?
  foodEntries           FoodEntry[]
  exerciseEntries       ExerciseEntry[]
  waterEntries          WaterEntry[]
  sleepEntries          SleepEntry[]
  dailyGoalSnapshots    DailyGoalSnapshot[]
  mealPlanEntries       MealPlanEntry[]

  // Provider reviews
  reviewsReceived   ProviderReview[] @relation("ReviewsReceived")
  reviewsGiven      ProviderReview[] @relation("ReviewsGiven")

  // Connection relations
  connectionsSent     UserConnection[] @relation("ConnectionsSent")
  connectionsReceived UserConnection[] @relation("ConnectionsReceived")

  // Preferences
  preferences         UserPreference?

  @@index([email])
  @@index([userType])
  @@index([verified, accountStatus])
  @@index([regionId])
}

// ─── Profile Tables (type-specific fields only) ─────────────────────────────

model PatientProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nationalId        String   @unique
  passportNumber    String?
  bloodType         String
  allergies         String[]
  chronicConditions String[]
  healthScore       Int      @default(50)

  // Patient-specific relations
  emergencyContact  PatientEmergencyContact?
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  vitalSigns        VitalSigns[]
  appointments      Appointment[]
  childcareBookings ChildcareBooking[]
  nurseBookings      NurseBooking[]
  pillReminders      PillReminder[]
  emergencyServices  EmergencyServiceContact[]
  nutritionAnalyses  NutritionAnalysis[]
  labTests           LabTest[]
  medicineOrders     MedicineOrder[]
  labTestBookings    LabTestBooking[]
  emergencyBookings  EmergencyBooking[]
  insuranceClaims    InsuranceClaim[]

  @@index([userId])
}

model DoctorProfile {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                 String // Specialist, General Practitioner
  specialty                String[]
  subSpecialties           String[]
  licenseNumber            String    @unique
  licenseExpiryDate        DateTime
  clinicAffiliation        String
  hospitalPrivileges       String[]
  rating                   Float     @default(0)
  reviewCount              Int       @default(0)
  experience               String
  publications             String[]
  awards                   String[]
  location                 String
  alternatePhone           String?
  website                  String?
  languages                String[]
  nextAvailable            DateTime?
  consultationDuration     Int       @default(30)
  consultationFee          Float
  videoConsultationFee     Float
  emergencyConsultationFee Float
  consultationTypes        String[] // video, in-person, home-visit
  emergencyAvailable       Boolean   @default(false)
  homeVisitAvailable       Boolean   @default(false)
  telemedicineAvailable    Boolean   @default(true)
  nationality              String?
  bio                      String
  philosophy               String?
  specialInterests         String[]
  verificationDate         DateTime?

  // Doctor-specific relations
  education       DoctorEducation[]
  certifications  DoctorCertification[]
  workHistory     DoctorWorkHistory[]
  patientComments PatientComment[]
  scheduleSlots   ScheduleSlot[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]
  services        DoctorServiceCatalog[]

  @@index([userId])
  @@index([category])
}

model DoctorServiceCatalog {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceName String
  category    String        // Consultation, Surgery, Screening, Therapy, Procedure, etc.
  description String
  price       Float
  currency    String        @default("MUR")
  duration    Int           @default(30) // minutes
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([doctorId])
  @@index([category])
}

model NurseProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int
  specializations String[]

  // Nurse-specific relations
  nurseBookings       NurseBooking[]
  nurseServiceCatalog NurseServiceCatalog[]

  @@index([userId])
}

model NannyProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience     Int
  certifications String[]

  // Nanny-specific relations
  childcareBookings       ChildcareBooking[]
  nannyServiceCatalog     NannyServiceCatalog[]

  @@index([userId])
}

model PharmacistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  pharmacyName    String
  pharmacyAddress String
  specializations String[]

  medicines PharmacyMedicine[]

  @@index([userId])
}

model LabTechProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  labName         String
  specializations String[]

  labTestCatalog  LabTestCatalog[]
  labTestBookings LabTestBooking[]

  @@index([userId])
}

model EmergencyWorkerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications String[]
  vehicleType    String? // ambulance, helicopter, motorcycle
  responseZone   String?
  emtLevel       String? // EMT-Basic, EMT-Intermediate, Paramedic

  serviceListings    EmergencyServiceListing[]
  emergencyBookings  EmergencyBooking[]

  @@index([userId])
}

model InsuranceRepProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  licenseNumber String?
  coverageTypes String[] // health, dental, vision, life

  planListings    InsurancePlanListing[]
  insuranceClaims InsuranceClaim[]

  @@index([userId])
}

model CorporateAdminProfile {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  registrationNumber String?
  employeeCount      Int?
  industry           String?

  @@index([userId])
}

model ReferralPartnerProfile {
  id             String @id @default(uuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessType   String
  commissionRate Float  @default(0)
  referralCode   String @unique
  totalReferrals Int    @default(0)

  @@index([userId])
}

model RegionalAdminProfile {
  id               String  @id @default(uuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  region           String
  country          String
  countryCode      String?
  commissionRate   Float   @default(10) // % of each transaction
  totalCommission  Float   @default(0)  // accumulated earnings

  @@index([userId])
  @@index([countryCode])
}

// ─── Clinical Models ─────────────────────────────────────────────────────────

model MedicalRecord {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      DoctorProfile? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  title       String
  date        DateTime
  type        String // consultation, prescription, lab_result, imaging, vaccination, surgery
  summary     String
  diagnosis   String?
  treatment   String?
  notes       String?
  attachments String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([type])
}

model Prescription {
  id         String         @id @default(uuid())
  patientId  String
  patient    PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  date       DateTime       @default(now())
  diagnosis  String
  isActive   Boolean        @default(true)
  nextRefill DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  medicines     PrescriptionMedicine[]
  pillReminders PillReminder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([isActive])
  @@index([date])
}

model Medicine {
  id          String  @id @default(uuid())
  name        String  @unique
  category    String
  description String?

  prescriptionMedicines PrescriptionMedicine[]
  orderItems            MedicineOrderItem[]
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  @@unique([prescriptionId, medicineId])
}

model VitalSigns {
  id               String         @id @default(uuid())
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedAt       DateTime       @default(now())
  systolicBP       Int?
  diastolicBP      Int?
  heartRate        Int?
  temperature      Float?
  weight           Float?
  height           Float?
  oxygenSaturation Int?
  glucose          Int?
  cholesterol      Int?
  facility         String?
  recordedBy       String?
  createdAt        DateTime       @default(now())

  @@index([patientId])
  @@index([recordedAt])
}

model LabTest {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testName    String
  category    String
  orderedAt   DateTime       @default(now())
  completedAt DateTime?
  status      String         @default("pending") // pending, in_progress, completed
  facility    String?
  orderedBy   String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  results LabTestResult[]

  @@index([patientId])
  @@index([status])
  @@index([orderedAt])
}

model LabTestResult {
  id           String  @id @default(uuid())
  labTestId    String
  labTest      LabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  parameter    String
  value        String
  unit         String?
  referenceMin String?
  referenceMax String?
  isAbnormal   Boolean @default(false)

  @@index([labTestId])
}

// ─── Scheduling Models ──────────────────────────────────────────────────────

model Appointment {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  scheduledAt DateTime
  type        String // video, in-person
  status      String         @default("pending") // pending, upcoming, completed, cancelled
  specialty   String
  reason      String
  duration    Int            @default(30)
  location    String?
  roomId      String?
  notes              String?
  cancellationReason String?
  cancelledBy        String?
  cancelledAt        DateTime?
  serviceName        String?
  servicePrice       Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([doctorId, patientId])
  @@index([doctorId, scheduledAt])
  @@index([status, scheduledAt])
}

model ScheduleSlot {
  id        String        @id @default(uuid())
  doctorId  String
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sunday, 6=Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean       @default(true)

  @@unique([doctorId, dayOfWeek, startTime])
  @@index([doctorId])
}

model NurseBooking {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nurseId     String
  nurse       NurseProfile   @relation(fields: [nurseId], references: [id], onDelete: Restrict)
  scheduledAt DateTime
  duration    Int
  type        String // in_person, home_visit, video
  status      String         @default("pending") // pending, upcoming, completed, cancelled
  reason      String?
  notes       String?
  serviceName String?
  servicePrice Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([patientId])
  @@index([nurseId])
  @@index([scheduledAt])
  @@index([status])
}

model ChildcareBooking {
  id                  String         @id @default(uuid())
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nannyId             String
  nanny               NannyProfile   @relation(fields: [nannyId], references: [id], onDelete: Restrict)
  scheduledAt         DateTime
  duration            Int
  type                String // in_person, home_visit, video
  children            String[]
  specialInstructions String?
  reason              String?
  serviceName         String?
  servicePrice        Float?
  status              String         @default("pending") // pending, upcoming, completed, cancelled
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([patientId])
  @@index([nannyId])
  @@index([scheduledAt])
  @@index([status])
}

// ─── WebRTC / Video Call Models ─────────────────────────────────────────────

model VideoRoom {
  id              String   @id @default(uuid())
  roomCode        String   @unique
  name            String?
  creatorId       String // User who created the room
  status          String   @default("active") // active, ended
  maxParticipants Int      @default(2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions     VideoCallSession[]
  participants VideoRoomParticipant[]

  @@index([roomCode])
  @@index([creatorId])
  @@index([status])
}

model VideoRoomParticipant {
  id       String    @id @default(uuid())
  roomId   String
  room     VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  role     String    @default("participant") // host, participant
  joinedAt DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model VideoCallSession {
  id          String    @id @default(uuid())
  roomId      String
  room        VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  duration    Int?
  callQuality String? // poor, fair, good, excellent
  status      String    @default("active") // active, ended, failed
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  connections WebRTCConnection[]

  @@index([roomId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model WebRTCConnection {
  id              String           @id @default(uuid())
  sessionId       String
  session         VideoCallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  userName        String
  socketId        String?
  connectionState String           @default("new") // new, connecting, connected, disconnected, failed
  iceState        String?
  signalData      Json?
  lastSeen        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([socketId])
}

// ─── Messaging Models ───────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("direct") // direct, group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([type])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([conversationId, senderId, readAt])
}

// ─── Supporting Models ──────────────────────────────────────────────────────

model PatientEmergencyContact {
  id           String         @id @default(uuid())
  patientId    String         @unique
  patient      PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone        String
  address      String?
}

model EmergencyServiceContact {
  id             String         @id @default(uuid())
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name           String
  service        String
  phone          String
  available24h   Boolean        @default(true)
  responseTime   String?
  specialization String[]
  location       String?
  priority       String         @default("medium") // high, medium, low

  @@index([patientId])
}

model BillingInfo {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String // mcb_juice, credit_card
  lastFour   String // Last 4 digits only
  cardHolder String
  expiryDate String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PillReminder {
  id                  String         @id @default(uuid())
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptionId      String
  prescription        Prescription   @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName        String
  dosage              String
  times               String[]
  frequency           String
  nextDose            DateTime?
  isActive            Boolean        @default(true)
  notificationEnabled Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([patientId])
  @@index([prescriptionId])
  @@index([isActive])
}

model NutritionAnalysis {
  id                  String         @id @default(uuid())
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  foodName            String
  date                DateTime       @default(now())
  calories            Int
  carbs               Int
  protein             Int
  fat                 Int
  vitamins            String[]
  healthScore         Int
  suggestions         String[]
  allergens           String[]
  nutritionalBenefits String[]
  mealType            String // breakfast, lunch, dinner, snack
  createdAt           DateTime       @default(now())

  @@index([patientId])
  @@index([date])
}

model Document {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  type       String // lab_report, prescription, imaging, insurance, id_proof, other
  url        String
  size       Int?
  uploadedAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model MedicineOrder {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status      String         @default("pending") // pending, confirmed, shipped, delivered, cancelled
  totalAmount Float
  pharmacy    String?
  orderedAt   DateTime       @default(now())
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items MedicineOrderItem[]

  @@index([patientId])
  @@index([status])
}

model MedicineOrderItem {
  id                 String            @id @default(uuid())
  orderId            String
  order              MedicineOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicineId         String
  medicine           Medicine          @relation(fields: [medicineId], references: [id])
  pharmacyMedicineId String?
  pharmacyMedicine   PharmacyMedicine? @relation(fields: [pharmacyMedicineId], references: [id])
  quantity           Int
  price              Float

  @@index([orderId])
  @@index([pharmacyMedicineId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // appointment, prescription, lab_result, message, system
  title     String
  message   String
  referenceId   String?
  referenceType String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@index([userId, readAt])
}

// ─── Doctor Supporting Models ───────────────────────────────────────────────

model DoctorEducation {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  degree      String
  institution String
  year        Int
  honors      String?

  @@index([doctorId])
}

model DoctorCertification {
  id           String        @id @default(uuid())
  doctorId     String
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
