generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User Type Enum ──────────────────────────────────────────────────────────

enum UserType {
  MEMBER // default for any authenticated non-provider — "member of MediWyz", not "sick patient"
  DOCTOR
  NURSE
  NANNY
  PHARMACIST
  LAB_TECHNICIAN
  EMERGENCY_WORKER
  INSURANCE_REP
  CORPORATE_ADMIN
  REFERRAL_PARTNER
  REGIONAL_ADMIN
  CAREGIVER
  PHYSIOTHERAPIST
  DENTIST
  OPTOMETRIST
  NUTRITIONIST
}

// ─── Provider Role Configuration (DB-driven, manageable by regional admin) ──

model ProviderRole {
  id            String  @id @default(uuid())
  code          String  @unique // UPPER_CASE: "DOCTOR", "AUDIOLOGIST", etc.
  label         String // Plural display: "Doctors", "Audiologists"
  singularLabel String // Singular: "Doctor", "Audiologist"
  slug          String  @unique // URL slug: "doctors", "audiologists"
  icon          String  @default("FaUserMd") // React icon name (legacy FA picker — kept for compat)
  iconKey       String? // Iconify format: "healthicons:doctor", "ph:stethoscope-duotone", "tabler:stethoscope"
  color         String  @default("#0C6780") // Brand color hex
  cardImage     String? // Optional card/logo image URL
  description   String? // Role description for signup page

  // Feature toggles
  searchEnabled       Boolean @default(true) // Show in patient search sidebar
  bookingEnabled      Boolean @default(true) // Patients can book this role
  inventoryEnabled    Boolean @default(true) // Can manage inventory / Health Shop
  isProvider          Boolean @default(true) // true=provider, false=non-provider (patient, admin)
  isActive            Boolean @default(true)
  displayOrder        Int     @default(100) // Sort order in sidebar/search
  defaultBookingFee   Float   @default(0) // Default consultation fee (DB-driven, no hardcoded map)
  skipWalletCheck     Boolean @default(false) // true = no wallet balance required (e.g., emergency services)
  requiredContentType String? // Auto-require content on completion (e.g., "lab_result", "dental_chart", "meal_plan")

  // Ownership
  regionCode       String? // null = global, "MU" = Mauritius-only
  createdByAdminId String? // null = system default

  // Registration: URL prefix + cookie value for auth
  urlPrefix   String? // "/doctor", "/audiologist" (used for routing)
  cookieValue String? // "doctor", "audiologist" (stored in auth cookie)

  // Profile form schema — DB-driven so new roles created via regional-admin
  // CRUD don't require any code change. Each entry:
  //   { key, label, type: 'text'|'number'|'tags'|'select'|'readonly', options?, suffix?, profileField? }
  profileFields Json? // null → no role-specific fields

  // Relations
  verificationDocs RoleVerificationDoc[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isProvider])
  @@index([regionCode])
}

model RoleVerificationDoc {
  id           String       @id @default(uuid())
  roleId       String
  role         ProviderRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  documentName String // "Medical License", "Pharmacy License", "ID Card"
  description  String? // Help text: "Upload a valid medical license issued by..."
  isRequired   Boolean      @default(true)
  displayOrder Int          @default(0)

  @@index([roleId])
}

// ─── Booking & Appointment Status Enums ────────────────────────────────────

// BookingStatus enum removed — all booking models use String for status
// (kept as comment for historical reference)

enum AppointmentType {
  video
  in_person
  home_visit
}

// EmergencyStatus enum removed — EmergencyBooking uses String for status
// (kept as comment for historical reference)

enum Priority {
  low
  medium
  high
  critical
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
  extra_active
}

enum WeightGoal {
  lose
  maintain
  gain
}

enum ExerciseIntensity {
  light
  moderate
  vigorous
}

enum SubscriptionPlanType {
  individual
  corporate
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  past_due
}

/// Wallet ledger entry direction. `credit` = money in (positive delta on
/// wallet.balance), `debit` = money out. Hardcoded into a Prisma enum so a
/// stray uppercase variant can't silently break admin analytics again.
enum WalletTxType {
  credit
  debit
}

/// Treasury ledger entry kind — fixed vocabulary that money-flow analytics
/// and the reconciliation job key off of.
enum TreasuryTxType {
  contribution
  platform_fee
  claim_payout
  direct_billing
}

enum CorporateEmployeeStatus {
  pending
  active
  removed
}

// ─── Region Model ────────────────────────────────────────────────────────────

model Region {
  id             String   @id @default(uuid())
  name           String   @unique
  countryCode    String   @unique
  language       String   @default("en")
  flag           String?
  currency       String   @default("MUR")
  currencySymbol String   @default("Rs")
  trialCredit    Float    @default(4500)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
}

// ─── Base User Model (auth + shared fields) ──────────────────────────────────

model User {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String    @unique
  password       String
  profileImage   String?
  coverImage     String?
  bio            String?    // Short self-description, shown on /profile/[id]
  phone          String
  userType       UserType
  dateOfBirth    DateTime?
  gender         String?
  address        String?
  latitude       Float?    // GPS coordinates for nearest-provider search
  longitude      Float?
  verified       Boolean   @default(false)
  accountStatus  String    @default("active") // active, suspended, pending
  referredByCode String? // Referral code used at signup
  regionId       String?
  region         Region?   @relation(fields: [regionId], references: [id])

  // Password reset (single-use token, 1h expiry)
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  // Security question for in-app password reset (no email provider needed)
  securityQuestion   String? // plain-text prompt
  securityAnswerHash String? // bcrypt hash of the (lowercased, trimmed) answer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1:1 optional profile relations (only one will be non-null per user)
  patientProfile         PatientProfile?
  doctorProfile          DoctorProfile?
  nurseProfile           NurseProfile?
  nannyProfile           NannyProfile?
  pharmacistProfile      PharmacistProfile?
  labTechProfile         LabTechProfile?
  emergencyWorkerProfile EmergencyWorkerProfile?
  insuranceRepProfile    InsuranceRepProfile?
  corporateAdminProfile  CorporateAdminProfile[]
  referralPartnerProfile ReferralPartnerProfile?
  regionalAdminProfile   RegionalAdminProfile?
  caregiverProfile       CaregiverProfile?
  physiotherapistProfile PhysiotherapistProfile?
  dentistProfile         DentistProfile?
  optometristProfile     OptometristProfile?
  nutritionistProfile    NutritionistProfile?

  // Cross-cutting relations (generic for all user types)
  videoCallSessions    VideoCallSession[]
  conversations        ConversationParticipant[]
  sentMessages         Message[]
  notifications        Notification[]
  billingInfo          BillingInfo[]
  documents            Document[]
  wallet               UserWallet?
  providerAvailability ProviderAvailability[]

  // Social / posts relations
  posts        Post[]        @relation("PostAuthor")
  postComments PostComment[] @relation("CommentAuthor")
  postLikes    PostLike[]    @relation("PostLiker")

  // AI Chat relations
  aiChatSessions    AiChatSession[]
  aiPatientInsights AiPatientInsight[]

  // Health Tracker relations
  healthTrackerProfile HealthTrackerProfile?
  foodEntries          FoodEntry[]
  exerciseEntries      ExerciseEntry[]
  waterEntries         WaterEntry[]
  sleepEntries         SleepEntry[]
  dailyGoalSnapshots   DailyGoalSnapshot[]
  mealPlanEntries      MealPlanEntry[]

  // Provider reviews
  reviewsReceived ProviderReview[] @relation("ReviewsReceived")
  reviewsGiven    ProviderReview[] @relation("ReviewsGiven")

  // Connection relations
  connectionsSent     UserConnection[] @relation("ConnectionsSent")
  connectionsReceived UserConnection[] @relation("ConnectionsReceived")

  // Preferences
  preferences UserPreference?

  // Subscription
  subscription         UserSubscription?
  corporateEmployments CorporateEmployee[] @relation("EmployeeUser")
  corporateEnrollments CorporateEmployee[] @relation("CorporateAdminUser")

  // Saved providers + insurance claim submissions + health streak
  favorites            ProviderFavorite[]         @relation("UserFavorites")
  favoritedBy          ProviderFavorite[]         @relation("ProviderFavoritedBy")
  claimSubmissions     InsuranceClaimSubmission[] @relation("MemberClaims")
  healthStreak         HealthStreak?
  insurancePolicies    InsurancePolicy[]          @relation("MemberPolicies")
  memberPreAuths       PreAuthorization[]         @relation("MemberPreAuths")
  providerPreAuths     PreAuthorization[]         @relation("ProviderPreAuths")

  // Healthcare entity workplaces (providers can belong to a clinic/hospital)
  workplaces           ProviderWorkplace[]
  foundedEntities      HealthcareEntity[]   @relation("EntityFounder")
  sentInvitations      WorkplaceInvitation[] @relation("InvitationSender")

  @@index([email])
  @@index([userType])
  @@index([verified, accountStatus])
  @@index([regionId])
}

// ─── Profile Tables (type-specific fields only) ─────────────────────────────

model PatientProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nationalId        String   @unique
  passportNumber    String?
  bloodType         String
  allergies         String[]
  chronicConditions String[]
  healthScore       Int      @default(50)

  // Patient-specific relations
  emergencyContact  PatientEmergencyContact?
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  vitalSigns        VitalSigns[]
  appointments      Appointment[]
  childcareBookings ChildcareBooking[]
  nurseBookings     NurseBooking[]
  pillReminders     PillReminder[]
  emergencyServices EmergencyServiceContact[]
  nutritionAnalyses NutritionAnalysis[]
  labTests          LabTest[]
  medicineOrders    MedicineOrder[]
  labTestBookings   LabTestBooking[]
  emergencyBookings EmergencyBooking[]
  insuranceClaims   InsuranceClaim[]

  @@index([userId])
}

model DoctorProfile {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty                String[] // e.g. ["General Practice", "Family Medicine"] — GP is just a specialty
  subSpecialties           String[]
  licenseNumber            String    @unique
  licenseExpiryDate        DateTime
  clinicAffiliation        String
  hospitalPrivileges       String[]
  rating                   Float     @default(0)
  reviewCount              Int       @default(0)
  experience               String
  publications             String[]
  awards                   String[]
  location                 String
  alternatePhone           String?
  website                  String?
  languages                String[]
  nextAvailable            DateTime?
  consultationDuration     Int       @default(30)
  consultationFee          Float
  videoConsultationFee     Float
  emergencyConsultationFee Float
  consultationTypes        String[] // video, in-person, home-visit
  emergencyAvailable       Boolean   @default(false)
  homeVisitAvailable       Boolean   @default(false)
  telemedicineAvailable    Boolean   @default(true)
  nationality              String?
  bio                      String
  philosophy               String?
  specialInterests         String[]
  verificationDate         DateTime?

  // Doctor-specific relations
  education       DoctorEducation[]
  certifications  DoctorCertification[]
  workHistory     DoctorWorkHistory[]
  patientComments PatientComment[]
  scheduleSlots   ScheduleSlot[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]
  services        DoctorServiceCatalog[]

  @@index([userId])
}

model DoctorServiceCatalog {
  id          String        @id @default(uuid())
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceName String
  category    String // Consultation, Surgery, Screening, Therapy, Procedure, etc.
  description String
  price       Float
  currency    String        @default("MUR")
  duration    Int           @default(30) // minutes
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([doctorId])
  @@index([category])
}

model NurseProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int
  specializations String[]

  // Nurse-specific relations
  nurseBookings       NurseBooking[]
  nurseServiceCatalog NurseServiceCatalog[]

  @@index([userId])
}

model NannyProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience     Int
  certifications String[]

  // Nanny-specific relations
  childcareBookings   ChildcareBooking[]
  nannyServiceCatalog NannyServiceCatalog[]

  @@index([userId])
}

model PharmacistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  pharmacyName    String
  pharmacyAddress String
  specializations String[]

  medicines PharmacyMedicine[]

  @@index([userId])
}

model LabTechProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  labName         String
  specializations String[]

  labTestCatalog  LabTestCatalog[]
  labTestBookings LabTestBooking[]

  @@index([userId])
}

model EmergencyWorkerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications String[]
  vehicleType    String? // ambulance, helicopter, motorcycle
  responseZone   String?
  emtLevel       String? // EMT-Basic, EMT-Intermediate, Paramedic

  serviceListings   EmergencyServiceListing[]
  emergencyBookings EmergencyBooking[]

  @@index([userId])
}

model InsuranceRepProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  licenseNumber String?
  coverageTypes String[] // health, dental, vision, life

  planListings    InsurancePlanListing[]
  insuranceClaims InsuranceClaim[]

  @@index([userId])
}

// Represents a company owned by any user (not just CORPORATE_ADMIN).
// Historically named "CorporateAdminProfile" — kept for backward compat.
model CorporateAdminProfile {
  id                 String  @id @default(uuid())
  // NOTE: userId is no longer @unique — a single user can own multiple
  // companies. The service layer protects against invariants (e.g. an
  // insurance owner can also run a regular corporate plan).
  userId             String
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  registrationNumber String?
  employeeCount      Int?
  industry           String?

  // Insurance-company flag — when true, members pay a monthly contribution.
  isInsuranceCompany  Boolean @default(false)
  monthlyContribution Float? // fixed per-company amount (MUR), insurance only
  coverageDescription String?

  // Subscription plan applied to all members of this company.
  subscriptionPlanId String?

  posts            Post[]
  claimSubmissions InsuranceClaimSubmission[]
  treasury         InsuranceCompanyTreasury?
  plans            InsurancePlan[]
  preAuthorizations PreAuthorization[]        @relation("CompanyPreAuths")

  @@index([userId])
  @@index([isInsuranceCompany])
}

model ReferralPartnerProfile {
  id                    String @id @default(uuid())
  userId                String @unique
  user                  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessType          String
  commissionRate        Float  @default(0)
  referralCode          String @unique
  totalReferrals        Int    @default(0)
  totalCommissionEarned Float  @default(0)

  @@index([userId])
}

model RegionalAdminProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  region          String
  country         String
  countryCode     String?
  commissionRate  Float   @default(10) // % of each transaction
  totalCommission Float   @default(0) // accumulated earnings

  @@index([userId])
  @@index([countryCode])
}

// ─── New Provider Profile Tables ─────────────────────────────────────────────

model CaregiverProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String?
  experience      Int      @default(0)
  specializations String[] // Elder Care, Disability Care, Dementia Care, etc.
  certifications  String[]

  @@index([userId])
}

model PhysiotherapistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // Orthopedic, Neurological, Sports, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model DentistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // General, Orthodontics, Periodontics, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model OptometristProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String   @unique
  experience      Int      @default(0)
  specializations String[] // General Eye Care, Pediatric, Contact Lenses, etc.
  clinicName      String?
  clinicAddress   String?

  @@index([userId])
}

model NutritionistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String?
  experience      Int      @default(0)
  specializations String[] // Clinical, Sports, Pediatric, Weight Management, etc.
  certifications  String[]

  @@index([userId])
}

// ─── Provider Specialties (database-driven, not hardcoded) ──────────────────

model ProviderSpecialty {
  id           String   @id @default(uuid())
  providerType UserType
  name         String
  description  String?
  icon         String? // Emoji or icon name (e.g. "❤️", "🧠", "🦴")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([providerType, name])
  @@index([providerType])
}

// ─── Health Programs ────────────────────────────────────────────────────────

model HealthProgram {
  id              String    @id @default(uuid())
  name            String
  description     String
  providerType    UserType
  specialty       String?
  durationWeeks   Int
  startDate       DateTime?
  endDate         DateTime?
  price           Float
  currency        String    @default("MUR")
  maxParticipants Int?
  countryCode     String?
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions    ProgramSession[]
  providers   ProgramProvider[]
  enrollments ProgramEnrollment[]
  planLinks   SubscriptionPlanProgram[]

  @@index([providerType])
  @@index([countryCode])
  @@index([createdByUserId])
  @@index([isActive])
}

model ProgramSession {
  id          String        @id @default(uuid())
  programId   String
  program     HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  weekNumber  Int
  serviceName String
  description String?
  duration    Int?
  sortOrder   Int           @default(0)

  progress ProgramSessionProgress[]

  @@index([programId])
}

model ProgramProvider {
  id        String        @id @default(uuid())
  programId String
  program   HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId    String
  role      String        @default("collaborator") // lead, collaborator
  joinedAt  DateTime      @default(now())

  @@unique([programId, userId])
  @@index([programId])
}

model ProgramEnrollment {
  id          String        @id @default(uuid())
  programId   String
  program     HealthProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  patientId   String
  status      String        @default("enrolled") // enrolled, in_progress, completed, dropped
  enrolledAt  DateTime      @default(now())
  completedAt DateTime?

  sessionProgress ProgramSessionProgress[]

  @@unique([programId, patientId])
  @@index([programId])
  @@index([patientId])
}

model ProgramSessionProgress {
  id           String            @id @default(uuid())
  enrollmentId String
  enrollment   ProgramEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sessionId    String
  session      ProgramSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status       String            @default("pending") // pending, scheduled, completed, missed
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  bookingId    String?

  @@unique([enrollmentId, sessionId])
  @@index([enrollmentId])
}

// ─── Subscription Plan Programs ─────────────────────────────────────────────

model SubscriptionPlanProgram {
  id              String           @id @default(uuid())
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  programId       String
  program         HealthProgram    @relation(fields: [programId], references: [id], onDelete: Cascade)
  isFree          Boolean          @default(false)
  discountPercent Int              @default(0)

  @@unique([planId, programId])
  @@index([planId])
}

// ─── Clinical Models ─────────────────────────────────────────────────────────

model MedicalRecord {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      DoctorProfile? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  title       String
  date        DateTime
  type        String // consultation, prescription, lab_result, imaging, vaccination, surgery
  summary     String
  diagnosis   String?
  treatment   String?
  notes       String?
  attachments String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([type])
}

model Prescription {
  id         String         @id @default(uuid())
  patientId  String
  patient    PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  date       DateTime       @default(now())
  diagnosis  String
  isActive   Boolean        @default(true)
  nextRefill DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  medicines     PrescriptionMedicine[]
  pillReminders PillReminder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([isActive])
  @@index([date])
}

model Medicine {
  id          String  @id @default(uuid())
  name        String  @unique
  category    String
  description String?

  prescriptionMedicines PrescriptionMedicine[]
  orderItems            MedicineOrderItem[]
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  @@unique([prescriptionId, medicineId])
}

model VitalSigns {
  id               String         @id @default(uuid())
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedAt       DateTime       @default(now())
  systolicBP       Int?
  diastolicBP      Int?
  heartRate        Int?
  temperature      Float?
  weight           Float?
  height           Float?
  oxygenSaturation Int?
  glucose          Int?
  cholesterol      Int?
  facility         String?
  recordedBy       String?
  createdAt        DateTime       @default(now())

  @@index([patientId])
  @@index([recordedAt])
}

model LabTest {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testName    String
  category    String
  orderedAt   DateTime       @default(now())
  completedAt DateTime?
  status      String         @default("pending") // pending, in_progress, completed
  facility    String?
  orderedBy   String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  results LabTestResult[]

  @@index([patientId])
  @@index([status])
  @@index([orderedAt])
}

model LabTestResult {
  id           String  @id @default(uuid())
  labTestId    String
  labTest      LabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)
  parameter    String
  value        String
  unit         String?
  referenceMin String?
  referenceMax String?
  isAbnormal   Boolean @default(false)

  @@index([labTestId])
}

