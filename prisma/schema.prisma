  date        DateTime
  sleepStart  DateTime?
  sleepEnd    DateTime?
  durationMin Int
  quality     SleepQuality @default(fair)
  notes       String?
  createdAt   DateTime     @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model DailyGoalSnapshot {
