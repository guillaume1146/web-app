  carbs       Float    @default(0)
  fat         Float    @default(0)
  fiber       Float    @default(0)
  quantity    Float    @default(1)
  unit        String   @default("serving")
  servingSize String?
  foodDbId    String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
  @@index([userId, mealType])
}

model ExerciseEntry {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  exerciseType   String
  durationMin    Int
  caloriesBurned Int
  intensity      ExerciseIntensity @default(moderate)
  notes          String?
  createdAt      DateTime          @default(now())

  @@index([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  @@index([userId, date])
}

// ─── Sleep Tracking ─────────────────────────────────────────────────────────

enum SleepQuality {
  terrible
  poor
  fair
  good
  excellent
}

model SleepEntry {
