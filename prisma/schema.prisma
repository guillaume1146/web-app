// ─── WebRTC / Video Call Models ─────────────────────────────────────────────

model VideoRoom {
  id              String   @id @default(uuid())
  roomCode        String   @unique
  name            String?
  creatorId       String // User who created the room
  status          String   @default("active") // active, ended
  maxParticipants Int      @default(2)
  mode            String   @default("video") // video | audio — audio-only skips the camera track
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions     VideoCallSession[]
  participants VideoRoomParticipant[]

  @@index([roomCode])
  @@index([creatorId])
  @@index([status])
}

model VideoRoomParticipant {
  id       String    @id @default(uuid())
  roomId   String
  room     VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  role     String    @default("participant") // host, participant
  joinedAt DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model VideoCallSession {
  id          String    @id @default(uuid())
  roomId      String
  room        VideoRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  duration    Int?
  callQuality String? // poor, fair, good, excellent
  status      String    @default("active") // active, ended, failed
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  connections WebRTCConnection[]

  @@index([roomId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model WebRTCConnection {
  id              String           @id @default(uuid())
  sessionId       String
  session         VideoCallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId          String
  userName        String
  socketId        String?
  connectionState String           @default("new") // new, connecting, connected, disconnected, failed
  iceState        String?
  signalData      Json?
  lastSeen        DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([socketId])
}

// ─── Messaging Models ───────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("direct") // direct, group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft-delete: rows with deletedAt set are hidden from normal queries.
  // Admin hard-delete path stays available via raw Prisma.
  deletedAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([type])
  @@index([deletedAt])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([conversationId, senderId, readAt])
}

