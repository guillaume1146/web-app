  imageUrl             String?
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  orderItems           MedicineOrderItem[]

  @@index([pharmacistId])
  @@index([category])
}

model LabTestCatalog {
  id             String         @id @default(uuid())
  labTechId      String
  labTech        LabTechProfile @relation(fields: [labTechId], references: [id], onDelete: Cascade)
